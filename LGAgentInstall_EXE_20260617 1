#requires -Version 5.1
<#
    Liongard Agent deployment script for the EXE-based installer bundle.

    The EXE bundle wraps the Liongard Agent MSI, the Visual C++ redistributable, and
    Npcap, making it the right choice for hosts that will run the Liongard network
    discovery inspector, which depends on those components.

    The script performs:
      • Partner configuration validation.
      • Environment-name resolution against the Liongard API.
      • A version gate that installs only when the bundle is newer than any agent
        already present on the host.
      • Proxy preflight handling for endpoints that route through a proxy.
      • Structured transcript logging.
      • Per-component (Agent / Visual C++ / Npcap) post-install validation.
      • Optional enablement of network discovery after installation.
      • A JSON run-summary artifact for RMM ingestion.

    To remove the agent, use the standalone Liongard Agent uninstall script.

    Written by David Chapman, Manager of Partner Support.
#>

# ============================================================
# Partner Configuration - Required
# Replace every REPLACE_WITH_* value before deploying.
# Only an agent install token is required to install/register the Liongard Agent. API tokens
# are NOT required for the base install — see the optional API-backed section further below.
# ============================================================
$InstancePrefix          = "REPLACE_WITH_INSTANCE_PREFIX"     # Liongard instance prefix (e.g. us1, us2, eu1)
$AgentTokenKey           = "REPLACE_WITH_AGENT_TOKEN_KEY"     # Liongard agent install key
$AgentTokenSecret        = "REPLACE_WITH_AGENT_TOKEN_SECRET"  # Liongard agent install secret
$Environment             = "REPLACE_WITH_ENVIRONMENT_NAME"    # Environment name (can be an RMM variable); required only when $IncludeEnvironmentValue = $true

# ============================================================
# Partner Configuration - Optional
# ============================================================
$AgentDescription        = ""        # Optional agent description shown in Liongard
$IncludeEnvironmentValue = $true     # Set to $false to omit the environment value

# Optional outbound proxy for this host (e.g. http://proxy.contoso.com:8080). Leave blank if none.
$ProxyUrl                = ""

# ============================================================
# Partner Configuration - Optional API-backed matching / validation
# These advanced features call the Liongard API and therefore REQUIRE API tokens. Both default
# to $false so the base agent install needs only the agent install token above. Enable one or
# both only when you intentionally want API-backed environment lookup or device validation
# (advanced partners / Liongard Support). When both are $false the script makes no API calls and
# API tokens are not required.
# ============================================================
$EnableEnvironmentNameMatching     = $false   # $true => resolve/normalize $Environment to the exact Liongard environment name via the API
$EnableEnvironmentDeviceValidation = $false   # $true => run the read-only environment/device validation advisory via the API
$ApiTokenKey             = "REPLACE_WITH_API_TOKEN_KEY"       # Liongard API token key    (required only when an API-backed feature above is enabled)
$ApiTokenSecret          = "REPLACE_WITH_API_TOKEN_SECRET"    # Liongard API token secret (required only when an API-backed feature above is enabled)

# ============================================================
# Advanced Defaults - Do Not Change Unless Directed by Liongard Support
# ============================================================
# This EXE bundle IS the Liongard network discovery / scanning deployment path. Choosing the EXE
# installer IS the discovery designation, so network discovery is implied and ALWAYS enabled: the
# bundle's enhanced-network-discovery flag (Npcap + Visual C++) is always passed, and
# network_discovery.yml is set to enabled after install/update/skip. These two values remain $true
# and exist only as a Support override; partners never change them, and there is no per-host opt-in.
$EnableNetworkDiscovery  = $true     # Always enable network discovery after install (EXE discovery path)
$InstallNpcap            = $true     # Always install Npcap + bundle Visual C++ (EXE discovery path)

# Installer source / locations.
$Folder                  = "C:\Liongard"
$InstallerUrl            = "https://agents.static.liongard.com/LiongardAgent-lts.exe"
$InstallerFileName       = "LiongardAgent-lts.exe"
$InstallerLogPath        = ""

# Installer behavior. Deployments always run fully silent (/quiet) with no endpoint prompt/window.
$EulaAccepted            = $true
$SuppressRestart         = $true

# MSI AUTOUPDATE property, forwarded through the bundle. $null leaves the installer default.
$AutoUpdate              = $null
$AutoUpdateArgumentName  = "AUTOUPDATE"

# Clear proxy environment variables for the installer process when an explicit $ProxyUrl is set.
$ClearProxyEnvironmentForInstaller = $true

# Update-safe parameter policy. Fresh installs pass the full parameter set; in-place UPDATES
# withhold registration/configuration parameters so a version-only update cannot move/overwrite
# the agent's URL, keys, name, environment, or description. Set $true ONLY if Support directs it.
$ReassertInstallParametersOnUpdate = $false

# Advisory environment/device validation (read-only). $true blocks a HIGH-confidence
# wrong-environment match before install/update (exit 11). A full MachineGuid match scores 100;
# do not lower the threshold for blocking.
$FailOnEnvironmentMismatch = $false
$EnvironmentValidationHighConfidenceThreshold = 100

$script:TranscriptStarted = $false
$script:TranscriptPath = $null
$script:EnvironmentResolutionReason = $null
$script:RunWarnings = New-Object System.Collections.Generic.List[string]
$script:RunErrors = New-Object System.Collections.Generic.List[string]
$script:SummaryArtifactPath = $null
$script:CurrentSection = $null

function Convert-ToStringArray {
    param([Parameter()][object]$Value)

    if ($null -eq $Value) { return @() }

    if ($Value -is [string]) {
        if ([string]::IsNullOrWhiteSpace($Value)) { return @() }
        return @($Value)
    }

    if ($Value -is [System.Collections.IEnumerable] -and -not ($Value -is [string])) {
        return @(
            $Value |
            ForEach-Object { if ($null -ne $_) { [string]$_ } } |
            Where-Object { -not [string]::IsNullOrWhiteSpace($_) }
        )
    }

    return @([string]$Value)
}

function Add-RunWarning {
    param([Parameter(Mandatory)][AllowEmptyString()][string]$Message)

    if ([string]::IsNullOrWhiteSpace($Message)) { return }
    $script:RunWarnings.Add($Message) | Out-Null
    Write-Warning $Message
}

function Start-LogSection {
    param([Parameter(Mandatory)][string]$Name)

    $script:CurrentSection = $Name
    Write-Host ("=== {0} ===" -f $Name)
}

function Write-SectionValue {
    param(
        [Parameter(Mandatory)][string]$Label,
        [Parameter()][object]$Value
    )

    $text = Convert-ValidationDetailToText -Detail $Value
    if ([string]::IsNullOrWhiteSpace($text)) {
        $text = '<none>'
    }

    Write-Host ("{0}: {1}" -f $Label, $text)
}

function Convert-ToPlainObject {
    param([Parameter()][object]$Value)

    if ($null -eq $Value) { return $null }

    if ($Value -is [string] -or
        $Value -is [bool] -or
        $Value -is [int] -or
        $Value -is [long] -or
        $Value -is [double] -or
        $Value -is [decimal]) {
        return $Value
    }

    if ($Value -is [System.Collections.IDictionary]) {
        $result = [ordered]@{}
        foreach ($key in $Value.Keys) {
            $result[$key] = Convert-ToPlainObject -Value $Value[$key]
        }
        return [pscustomobject]$result
    }

    if ($Value -is [System.Collections.IEnumerable] -and -not ($Value -is [string])) {
        $items = @()
        foreach ($item in $Value) {
            $items += ,(Convert-ToPlainObject -Value $item)
        }
        return @($items)
    }

    if ($Value.PSObject -and $Value.PSObject.Properties.Count -gt 0) {
        $result = [ordered]@{}
        foreach ($property in $Value.PSObject.Properties) {
            $result[$property.Name] = Convert-ToPlainObject -Value $property.Value
        }
        return [pscustomobject]$result
    }

    return [string]$Value
}

function Complete-LogSection {
    if ($script:CurrentSection) {
        Write-Host ('=' * ([Math]::Max(20, $script:CurrentSection.Length + 8)))
        $script:CurrentSection = $null
    }
    else {
        Write-Host "============================"
    }
}

function Assert-ConfigurationValue {
    param(
        [string]$Name,
        [string]$Value
    )

    if ([string]::IsNullOrWhiteSpace($Value) -or $Value -like 'REPLACE_WITH_*') {
        throw "Configuration value [$Name] must be provided before running this script."
    }
}

function Get-LiongardServiceNames {
    return @(
        'roaragent',
        'roaragent.exe',
        'LiongardAgentSVC',
        'LiongardAgent',
        'Liongard Agent'
    )
}

function ConvertTo-SafeArray {
    # Build-safe collection -> object[]. On Windows PowerShell 5.1 (e.g. 5.1.20348) the array
    # subexpression @() over a System.Collections.Generic.List throws "Argument types do not
    # match" when $ErrorActionPreference = 'Stop'. Routing through the pipeline avoids it, so
    # every "@($collection)" site is funneled through here.
    param([Parameter()] $Value)
    if ($null -eq $Value) { return @() }
    return @($Value | Write-Output)
}
function Get-ServiceSafe {
    # Resilient wrapper around Get-Service. On some hosts (e.g. machines with per-user service
    # instances such as CDPUserSvc_*/OneSyncSvc_*) Get-Service can raise a TERMINATING .NET
    # exception ("Argument types do not match") while the Service Control Manager enumerates
    # services -- which -ErrorAction (non-terminating only) does NOT trap. These service checks
    # are read-only/idempotent and must never abort the run, so a failure degrades to $null
    # (treated the same as "service not present"; registry/CIM signals remain authoritative).
    param([Parameter(Mandatory)][string]$Name)
    try {
        return Get-Service -Name $Name -ErrorAction SilentlyContinue
    }
    catch {
        return $null
    }
}

# ================================
# Phase 1 - Read-only detection & reporting helpers
# These functions only READ local state (registry, services, CIM, DNS). They never
# modify the system and are used solely for richer logging and the run summary.
# ================================
function Get-IsElevated {
    # Reports whether the current context is elevated (Administrator) or SYSTEM.
    # Read-only: the result is logged but does NOT change any behavior in this phase.
    try {
        $identity = [System.Security.Principal.WindowsIdentity]::GetCurrent()
        $principal = New-Object System.Security.Principal.WindowsPrincipal($identity)
        return [bool]$principal.IsInRole([System.Security.Principal.WindowsBuiltInRole]::Administrator)
    }
    catch {
        return $false
    }
}

function Get-LocalDeviceIdentity {
    # Collects local machine identifiers for reporting and future device matching.
    # Mirrors the identifier logic used by the uninstall script. Never throws.
    $machineGuid = $null
    try {
        $cryptoPath = 'HKLM:\SOFTWARE\Microsoft\Cryptography'
        if (Test-Path -LiteralPath $cryptoPath) {
            $value = (Get-ItemProperty -LiteralPath $cryptoPath -Name 'MachineGuid' -ErrorAction SilentlyContinue).MachineGuid
            if (-not [string]::IsNullOrWhiteSpace($value)) { $machineGuid = $value.Trim() }
        }
    }
    catch { }

    $hardwareUuid = $null
    try {
        $uuid = (Get-CimInstance -ClassName Win32_ComputerSystemProduct -ErrorAction Stop).UUID
        if (-not [string]::IsNullOrWhiteSpace($uuid) -and
            $uuid -notmatch '^(00000000-0000-0000-0000-000000000000|FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF)$') {
            $hardwareUuid = $uuid.Trim()
        }
    }
    catch { }

    $netbios = $env:COMPUTERNAME
    $hostName = $null
    try { $hostName = [System.Net.Dns]::GetHostName() } catch { }

    $fqdn = $null
    try {
        $resolved = [System.Net.Dns]::GetHostEntry('localhost').HostName
        if (-not [string]::IsNullOrWhiteSpace($resolved)) { $fqdn = $resolved }
    }
    catch { }

    $macAddresses = New-Object System.Collections.Generic.List[string]
    try {
        $adapters = Get-CimInstance -ClassName Win32_NetworkAdapterConfiguration -Filter "IPEnabled = True" -ErrorAction Stop
        foreach ($adapter in $adapters) {
            if (-not [string]::IsNullOrWhiteSpace($adapter.MACAddress)) {
                $macAddresses.Add($adapter.MACAddress) | Out-Null
            }
        }
    }
    catch { }

    return [pscustomobject]@{
        MachineGuid  = $machineGuid
        HardwareUuid = $hardwareUuid
        NetbiosName  = $netbios
        Hostname     = $hostName
        Fqdn         = $fqdn
        MacAddresses = @($macAddresses | Select-Object -Unique)
    }
}

function Get-LiongardServiceHealth {
    # Returns the status of each known Liongard service name that is present on the host.
    $statuses = New-Object System.Collections.Generic.List[object]
    foreach ($svcName in (Get-LiongardServiceNames | Select-Object -Unique)) {
        $svc = Get-ServiceSafe -Name $svcName
        if ($svc) {
            $statuses.Add([pscustomobject]@{ Name = $svcName; Status = [string]$svc.Status }) | Out-Null
        }
    }
    return (ConvertTo-SafeArray $statuses)
}

function Test-LiongardAgentRegistryPresent {
    # True if a Liongard Agent uninstall entry is present in either registry view. Uses a
    # ProductCode-agnostic scan (DisplayName / Publisher, plus the legacy product code as a fallback
    # candidate), so a modern agent that registers under a different product code is still detected.
    return (@(Get-LiongardUninstallMatches).Count -gt 0)
}

function Get-LiongardDetectionSnapshot {
    # Classifies the local agent state for reporting only. Distinguishes registry-present
    # from service-present, and running from stopped. Does NOT change any behavior.
    $registryPresent = Test-LiongardAgentRegistryPresent
    $services = @(Get-LiongardServiceHealth)
    $servicePresent = ($services.Count -gt 0)
    $running = (@($services | Where-Object { $_.Status -eq 'Running' }).Count -gt 0)

    $state =
        if ($registryPresent -and $servicePresent -and $running) { 'InstalledServiceRunning' }
        elseif ($registryPresent -and $servicePresent) { 'InstalledServiceStopped' }
        elseif ($registryPresent -and -not $servicePresent) { 'InstalledServiceMissing' }
        elseif (-not $registryPresent -and $servicePresent) { 'ServicePresentRegistryMissing' }
        else { 'NotDetected' }

    return [pscustomobject]@{
        RegistryPresent = $registryPresent
        ServicePresent  = $servicePresent
        ServiceRunning  = $running
        Services        = $services
        State           = $state
    }
}

# ================================
# Phase 2 - Standardized script exit codes
# These map run outcomes to stable codes for Intune/RMM. They are SEPARATE from raw
# MSI/EXE installer codes (see Get-ExitCodeText), which remain in logs/JSON.
# ================================
function Get-ScriptExitCodeMeaning {
    param([int]$Code)
    switch ($Code) {
        0  { 'Success' }
        2  { 'Success, reboot required' }
        10 { 'Not running as admin' }
        11 { 'Configuration validation failure' }
        20 { 'Download failure' }
        21 { 'Installer missing or unreadable' }
        40 { 'Install failure' }
        41 { 'Update failure' }
        42 { 'Dependency failure' }
        43 { 'Partial validation failure' }
        50 { 'Uninstall failure' }
        51 { 'Remote platform deletion skipped due to low confidence' }
        1  { 'Unexpected exception' }
        default { 'Unknown' }
    }
}

function Resolve-ExeScriptExitCode {
    # Maps the EXE run's final status + active stage to a standardized script exit code.
    # Does NOT change what the installer does; only how the outcome is reported.
    param(
        [string]$Stage,
        [string]$FinalStatus,
        [int]$InstallerExitCode,
        [bool]$IsUpgrade
    )

    switch ($FinalStatus) {
        'EnvironmentMismatchBlocked' { return 11 }
        'SkippedUpToDate'     { return 0 }
        'Success'             { if ($InstallerExitCode -eq 3010) { return 2 } else { return 0 } }
        'SuccessWithWarnings' { if ($InstallerExitCode -eq 3010) { return 2 } else { return 0 } }
        # Phase 5: a designated discovery host whose required dependency (Npcap/VC++) did not
        # validate. Reboot-required takes precedence (the dependency may validate after reboot).
        'DependencyFailed'    { if ($InstallerExitCode -eq 3010) { return 2 } else { return 42 } }
        'PartialValidation'   { return 43 }
    }

    # Remaining states are failures; classify by the stage that was active when it occurred.
    switch ($Stage) {
        'Config'                { return 11 }
        'EnvironmentResolution' { return 11 }
        'Download'              { return 20 }
        'Install'               { if ($IsUpgrade) { return 41 } else { return 40 } }
        default                 { return 1 }
    }
}

function Test-LiongardAgentInstalled {
    # ProductCode-agnostic presence check (uninstall entry by DisplayName/Publisher/legacy code, OR
    # service, OR install folder). Delegates to Get-LiongardAgentInstallInfo so detection no longer
    # depends solely on the legacy product code {1D89F069-...}.
    return [bool](Get-LiongardAgentInstallInfo).Installed
}

function Get-LiongardAgentDetectionDetails {
    $details = New-Object System.Collections.Generic.List[string]

    foreach ($path in @(
            "HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\{1D89F069-B48B-4191-8810-2364C29EC039}",
            "HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\{1D89F069-B48B-4191-8810-2364C29EC039}"
        )) {
        if (Test-Path -LiteralPath $path) {
            $details.Add("Uninstall key present: $path") | Out-Null
        }
    }

    foreach ($svcName in (Get-LiongardServiceNames | Select-Object -Unique)) {
        $service = Get-ServiceSafe -Name $svcName
        if ($service) {
            $details.Add("Service '$svcName' detected with status $($service.Status)") | Out-Null
        }
    }

    foreach ($path in @(
            'C:\Program Files (x86)\LiongardInc\LiongardAgent\roaragent.exe',
            'C:\Program Files (x86)\LiongardInc\LiongardAgent\LiongardAgent.exe',
            'C:\Program Files (x86)\LiongardInc\LiongardAgent'
        )) {
        if (Test-Path -LiteralPath $path) {
            $details.Add("Path present: $path") | Out-Null
        }
    }

    return $details.ToArray()
}

function Get-InstalledAgentVersion {
    # Reads the DisplayVersion of the installed Liongard Agent from the uninstall
    # registry keys. Returns a [version] object, or $null if the agent is not found
    # or the version string cannot be parsed.
    $uninstallPaths = @(
        'HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\{1D89F069-B48B-4191-8810-2364C29EC039}',
        'HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\{1D89F069-B48B-4191-8810-2364C29EC039}'
    )

    foreach ($path in $uninstallPaths) {
        if (Test-Path -LiteralPath $path) {
            $ver = (Get-ItemProperty -LiteralPath $path -ErrorAction SilentlyContinue).DisplayVersion
            if (-not [string]::IsNullOrWhiteSpace($ver)) {
                try { return [version]$ver } catch { }
            }
        }
    }

    return $null
}

function Get-LiongardUninstallMatches {
    # ProductCode-agnostic scan of the Windows Installer uninstall hives (machine + WOW6432Node) for
    # the Liongard Agent. Matches on DisplayName (Liongard / Roar Agent) or Publisher (Liongard), and
    # always includes the known legacy product code as a fallback candidate. Read-only; never throws;
    # uses NO Win32_Product (which can trigger MSI repair/reconfigure). Returns an array of matches
    # with DisplayName / DisplayVersion / parsed Version / Publisher / ProductCode / KeyPath /
    # MatchMethod / IsLegacyCode.
    $legacyCode = '{1D89F069-B48B-4191-8810-2364C29EC039}'
    $roots = @(
        'HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall',
        'HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'
    )

    $results = New-Object System.Collections.Generic.List[object]
    foreach ($root in $roots) {
        if (-not (Test-Path -LiteralPath $root)) { continue }
        $keys = $null
        try { $keys = Get-ChildItem -LiteralPath $root -ErrorAction Stop } catch { continue }
        foreach ($k in $keys) {
            $props = $null
            try { $props = Get-ItemProperty -LiteralPath $k.PSPath -ErrorAction Stop } catch { continue }
            $dn  = [string]$props.DisplayName
            $pub = [string]$props.Publisher
            $keyName = $k.PSChildName

            $isLegacy  = ($keyName -eq $legacyCode)
            $nameMatch = ($dn -match '(?i)(liongard|roar)\s*agent' -or $dn -match '(?i)\bliongard\b')
            $pubMatch  = ($pub -match '(?i)liongard')
            if (-not ($nameMatch -or $pubMatch -or $isLegacy)) { continue }

            $ver = $null
            if (-not [string]::IsNullOrWhiteSpace($props.DisplayVersion)) {
                try { $ver = [version]([string]$props.DisplayVersion).Trim() } catch { }
            }

            $method = if ($nameMatch) { 'DisplayName' } elseif ($pubMatch) { 'Publisher' } else { 'LegacyProductCode' }
            $results.Add([pscustomobject]@{
                DisplayName    = $dn
                DisplayVersion = $props.DisplayVersion
                Version        = $ver
                Publisher      = $pub
                ProductCode    = $keyName
                KeyPath        = $k.PSPath
                MatchMethod    = $method
                IsLegacyCode   = $isLegacy
            }) | Out-Null
        }
    }
    return $results.ToArray()
}

function Get-LiongardAgentInstallInfo {
    # Stable, ProductCode-agnostic detection of the installed Liongard Agent and its version. The old
    # behavior read DisplayVersion from ONLY the legacy product code {1D89F069-...}; modern agents
    # register under different product codes (e.g. the MSI {9E287513-...} and the EXE bundle
    # {E43B859D-...}), so that single-code read silently failed and the version gate fell through to
    # an unnecessary update. This helper uses multiple reliable signals (registry/service/file reads
    # only -- NO Win32_Product) in priority order. Never throws.
    #
    # Version source priority:
    #   1. Liongard registry version value (HKLM:\SOFTWARE\[WOW6432Node\]Liongard\LiongardAgent), if a
    #      stable value such as AgentVersion/Version/DisplayVersion is present. (Current builds store
    #      only MachineID\AgentGuid here -- no version -- so this is best-effort/forward-looking.)
    #   2. Uninstall-registry DisplayVersion from the highest-version Liongard/Roar match.
    #   3. Installed executable file version (roaragent.exe / LiongardAgent.exe).
    #   4. Legacy product code DisplayVersion -- fallback only (covered by the uninstall scan above).
    #
    # "Installed" is determined from uninstall entry OR service OR install folder/exe. The Liongard
    # registry hive is deliberately NOT used to decide "installed", because MachineID\AgentGuid can
    # survive an uninstall as an orphan and would cause a false positive.
    $warnings = New-Object System.Collections.Generic.List[string]

    # 1. Liongard registry version value (forward-looking; absent on current builds).
    $liongardVersion = $null
    $liongardVersionSource = $null
    foreach ($hive in @('HKLM:\SOFTWARE\WOW6432Node\Liongard\LiongardAgent', 'HKLM:\SOFTWARE\Liongard\LiongardAgent')) {
        if (-not (Test-Path -LiteralPath $hive)) { continue }
        $hp = Get-ItemProperty -LiteralPath $hive -ErrorAction SilentlyContinue
        foreach ($vn in @('AgentVersion', 'Version', 'DisplayVersion')) {
            $raw = $hp.$vn
            if (-not [string]::IsNullOrWhiteSpace($raw)) {
                try { $liongardVersion = [version]([string]$raw).Trim(); $liongardVersionSource = "LiongardRegistry($hive\$vn)"; break } catch { }
            }
        }
        if ($liongardVersion) { break }
    }

    # 2. Uninstall-registry matches (ProductCode-agnostic).
    $uninstallMatches = @(Get-LiongardUninstallMatches)
    $bestUninstall = $uninstallMatches | Where-Object { $_.Version } | Sort-Object Version -Descending | Select-Object -First 1
    if (-not $bestUninstall -and $uninstallMatches.Count -gt 0) { $bestUninstall = $uninstallMatches[0] }

    # 3. Executable file-version fallback.
    $fileVersion = $null
    $fileVersionPath = $null
    foreach ($exe in @('C:\Program Files (x86)\LiongardInc\LiongardAgent\roaragent.exe', 'C:\Program Files (x86)\LiongardInc\LiongardAgent\LiongardAgent.exe')) {
        if (-not (Test-Path -LiteralPath $exe)) { continue }
        try {
            $vi = (Get-Item -LiteralPath $exe -ErrorAction Stop).VersionInfo
            foreach ($cand in @($vi.ProductVersion, $vi.FileVersion)) {
                if ($cand -and ($cand -match '\d+(\.\d+){1,3}')) { try { $fileVersion = [version]$Matches[0]; $fileVersionPath = $exe; break } catch { } }
            }
        }
        catch { }
        if ($fileVersion) { break }
    }

    # Service + install-folder presence.
    $servicePresent = $false
    foreach ($svc in (Get-LiongardServiceNames | Select-Object -Unique)) {
        if (Get-ServiceSafe -Name $svc) { $servicePresent = $true; break }
    }
    $folderPresent = $false
    foreach ($p in @('C:\Program Files (x86)\LiongardInc\LiongardAgent\roaragent.exe', 'C:\Program Files (x86)\LiongardInc\LiongardAgent\LiongardAgent.exe', 'C:\Program Files (x86)\LiongardInc\LiongardAgent')) {
        if (Test-Path -LiteralPath $p) { $folderPresent = $true; break }
    }

    $uninstallPresent = ($uninstallMatches.Count -gt 0)
    $installed = ($uninstallPresent -or $servicePresent -or $folderPresent)

    $methods = @()
    if ($uninstallPresent) { $methods += 'UninstallEntry' }
    if ($servicePresent)   { $methods += 'Service' }
    if ($folderPresent)    { $methods += 'InstallFolder' }
    $detectionMethod = if ($methods.Count -gt 0) { $methods -join '+' } else { 'NotDetected' }

    # Resolve version + source by priority.
    $version = $null; $versionSource = 'Unknown'; $productCode = $null; $keyPath = $null
    if ($liongardVersion) {
        $version = $liongardVersion; $versionSource = $liongardVersionSource
    }
    elseif ($bestUninstall -and $bestUninstall.Version) {
        $version = $bestUninstall.Version
        $versionSource = if ($bestUninstall.IsLegacyCode) { 'LegacyProductCodeDisplayVersion' } else { 'UninstallRegistryDisplayVersion' }
    }
    elseif ($fileVersion) {
        $version = $fileVersion; $versionSource = "FileVersion($fileVersionPath)"
    }
    if ($bestUninstall) { $productCode = $bestUninstall.ProductCode; $keyPath = $bestUninstall.KeyPath }

    if ($installed -and -not $version) {
        if ($uninstallPresent) {
            $warnings.Add('Liongard Agent is installed (uninstall entry present) but no parseable DisplayVersion/registry/file version was found; installed version treated as unknown.') | Out-Null
        }
        else {
            $warnings.Add('Liongard Agent detected via service/folder only (no uninstall entry); installed version could not be determined.') | Out-Null
        }
    }

    return [pscustomobject]@{
        Installed        = $installed
        Version          = $version
        VersionSource    = $versionSource
        DetectionMethod  = $detectionMethod
        ProductCode      = $productCode
        # UpgradeCode is intentionally not resolved: it is not stored in the uninstall hive, and
        # enumerating Installer\UpgradeCodes / MSI COM is heavy and brittle in PS 5.1. Registry
        # scanning by DisplayName/Publisher is sufficient and ProductCode-agnostic.
        UpgradeCode      = $null
        UninstallKeyPath = $keyPath
        ServicePresent   = $servicePresent
        UninstallMatches = $uninstallMatches
        Warnings         = $warnings.ToArray()
    }
}

function Get-InstallerBundleVersion {
    # Reads the bundle version from the downloaded EXE's file version info. The WiX
    # bootstrapper bundle exposes its version via ProductVersion/FileVersion. Returns
    # a [version] object, or $null when the value is missing or cannot be parsed.
    # NOTE: the bundle version may differ slightly from the agent MSI's DisplayVersion,
    # so the EXE's own downgrade protection (exit code 1638) remains the real backstop.
    param([Parameter(Mandatory)][string]$Path)

    try {
        $info = (Get-Item -LiteralPath $Path -ErrorAction Stop).VersionInfo
        foreach ($candidate in @($info.ProductVersion, $info.FileVersion)) {
            if ([string]::IsNullOrWhiteSpace($candidate)) { continue }
            if ($candidate -match '\d+(\.\d+){1,3}') {
                try { return [version]$Matches[0] } catch { }
            }
        }
    }
    catch {
        Write-Warning "Unable to read installer bundle version from [$Path]: $($_.Exception.Message)"
    }

    return $null
}

function Get-ExitCodeText {
    param([int]$Code)
    switch ($Code) {
        0     { 'Success' }
        3010  { 'Success, restart required' }
        1602  { 'User cancelled' }
        1603  { 'Fatal error during installation' }
        1618  { 'Another install in progress' }
        1638  { 'Another version is already installed' }
        1619  { 'Could not open installation package' }
        1622  { 'Error opening installation log file' }
        default { 'Unknown / check installer log' }
    }
}

function Start-LiongardTranscript {
    param([Parameter(Mandatory)][string]$TargetFolder)

    if (-not (Test-Path -LiteralPath $TargetFolder)) {
        try {
            New-Item -Path $TargetFolder -ItemType Directory -Force | Out-Null
        }
        catch {
            Write-Warning "Unable to create folder [$TargetFolder] for transcript logging: $($_.Exception.Message)"
            return
        }
    }

    $timestamp = Get-Date -Format 'yyyyMMdd_HHmmss'
    $script:TranscriptPath = Join-Path -Path $TargetFolder -ChildPath ("LGAgentScript_EXE_{0}.log" -f $timestamp)

    try {
        Start-Transcript -Path $script:TranscriptPath -Force | Out-Null
        $script:TranscriptStarted = $true
        Write-Host "Script transcript logging enabled at [$script:TranscriptPath]."
    }
    catch {
        Write-Warning "Unable to start transcript logging at [$script:TranscriptPath]: $($_.Exception.Message)"
        $script:TranscriptPath = $null
    }
}

function Stop-LiongardTranscript {
    if (-not $script:TranscriptStarted) { return }

    try {
        Stop-Transcript | Out-Null
        if ($script:TranscriptPath) {
            Write-Host "Script transcript saved to [$script:TranscriptPath]."
        }
    }
    catch {
        Write-Warning "Failed to finalize transcript logging: $($_.Exception.Message)"
    }
    finally {
        $script:TranscriptStarted = $false
        $script:TranscriptPath = $null
    }
}

function Write-RegistryLog {
    param(
        [ValidateSet('INFO','STEP','OK','WARN','ERROR')]
        [string]$Level,
        [string]$Message
    )

    $line = "[Registry][$Level] $Message"
    switch ($Level) {
        'WARN'  { Write-Warning $line }
        'ERROR' { Write-Error   $line }
        default { Write-Host    $line }
    }
}

function Get-ObjectPropertyValue {
    param(
        [Parameter()][object]$Object,
        [Parameter()][string]$Name,
        [Parameter()][object]$Default = $null
    )

    if ($null -eq $Object -or [string]::IsNullOrEmpty($Name)) { return $Default }
    $property = $Object.PSObject.Properties[$Name]
    if ($null -eq $property) { return $Default }
    return $property.Value
}

function Ensure-RegistryDrive {
    param(
        [Parameter(Mandatory)][string]$Name,
        [Parameter(Mandatory)][string]$Root
    )

    if (Get-PSDrive -Name $Name -ErrorAction SilentlyContinue) { return }

    try {
        New-PSDrive -Name $Name -PSProvider Registry -Root $Root -Scope Script -ErrorAction Stop | Out-Null
        Write-RegistryLog INFO "Mounted registry drive '${Name}:' at $Root for enumeration."
    }
    catch {
        Write-RegistryLog WARN "Failed to mount registry drive '${Name}:' ($Root): $($_.Exception.Message)"
    }
}

function Get-UninstallEntries {
    param(
        [string[]]$Names,
        [pscustomobject[]]$ProductCodes
    )

    $tokens = $Names | Where-Object { -not [string]::IsNullOrWhiteSpace($_) } | ForEach-Object { $_.ToLowerInvariant() }
    $seenPaths = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)

    $roots = @(
        @{ Path = 'HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall';             Scope = 'Machine' },
        @{ Path = 'HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'; Scope = 'Machine' },
        @{ Path = 'HKCU:\Software\Microsoft\Windows\CurrentVersion\Uninstall';             Scope = 'CurrentUser' },
        @{ Path = 'HKCU:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall'; Scope = 'CurrentUser' }
    )

    Ensure-RegistryDrive -Name 'HKU' -Root 'HKEY_USERS'

    try {
        $userRoots = Get-ChildItem HKU: -ErrorAction Stop | Where-Object { $_.PSChildName -match '^S-1-5-21' }
        foreach ($sid in $userRoots) {
            $sidBase = "HKU:\$($sid.PSChildName)\Software\Microsoft\Windows\CurrentVersion\Uninstall"
            $roots += @{ Path = $sidBase; Scope = "User:$($sid.PSChildName)" }
            $roots += @{ Path = "$sidBase\WOW6432Node"; Scope = "User:$($sid.PSChildName)" }
        }
    }
    catch {
        Write-RegistryLog WARN "Unable to enumerate HKU hives: $($_.Exception.Message)"
    }

    $found = @()
    foreach ($root in $roots) {
        $path = $root.Path
        if (-not (Test-Path $path)) { continue }

        try {
            $keys = Get-ChildItem -Path $path -ErrorAction Stop
        }
        catch {
            Write-RegistryLog WARN "Skipping uninstall root '$path' due to access error: $($_.Exception.Message)"
            continue
        }

        foreach ($k in $keys) {
            try {
                $props = Get-ItemProperty -LiteralPath $k.PSPath -ErrorAction Stop
            }
            catch {
                Write-RegistryLog WARN "Skipping uninstall key due to read error: $($_.Exception.Message)"
                continue
            }

            $display = Get-ObjectPropertyValue -Object $props -Name 'DisplayName'
            $keyName = $k.PSChildName
            $haystack = @($display, $keyName) | Where-Object { -not [string]::IsNullOrWhiteSpace($_) }
            $haystackLower = $haystack | ForEach-Object { $_.ToLowerInvariant() }

            $isMatch = $false
            foreach ($token in $tokens) {
                if ($haystackLower | Where-Object { $_ -like "*$token*" }) {
                    $isMatch = $true
                    break
                }
            }

            if (-not $isMatch) { continue }

            $friendlyName = if ($display) { $display } elseif ($keyName) { $keyName } else { '(Unnamed entry)' }
            if (-not $seenPaths.Add($k.PSPath)) { continue }

            $found += [pscustomobject]@{
                DisplayName = $display
                Name        = $friendlyName
                Quiet       = Get-ObjectPropertyValue -Object $props -Name 'QuietUninstallString'
                Normal      = Get-ObjectPropertyValue -Object $props -Name 'UninstallString'
                KeyPath     = $k.PSPath
                KeyName     = $keyName
                Scope       = $root.Scope
                ProductCode = if ($keyName -and $keyName -match '^\{[0-9A-F\-]+\}$') { $keyName } else { $null }
            }
        }
    }

    foreach ($pc in $ProductCodes) {
        if (-not $pc.Code) { continue }
        $code = $pc.Code
        $candidatePaths = @(
            "HKLM:\Software\Microsoft\Windows\CurrentVersion\Uninstall\$code",
            "HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\$code"
        )

        foreach ($kp in $candidatePaths) {
            try {
                if (-not (Test-Path -LiteralPath $kp)) { continue }
                $item = Get-Item -LiteralPath $kp -ErrorAction Stop
                $props = Get-ItemProperty -LiteralPath $kp -ErrorAction Stop
                $display = Get-ObjectPropertyValue -Object $props -Name 'DisplayName'
                $friendlyName = if ($display) { $display } elseif ($pc.Name) { $pc.Name } else { "$code (MSI)" }
                $scope = if ($kp -like 'HKLM:\*') { 'Machine (known)' } else { 'User (known)' }

                if (-not $seenPaths.Add($item.PSPath)) { continue }

                Write-RegistryLog INFO "Including known uninstall entry fallback: $friendlyName -> $kp"

                $found += [pscustomobject]@{
                    DisplayName = $display
                    Name        = $friendlyName
                    Quiet       = Get-ObjectPropertyValue -Object $props -Name 'QuietUninstallString'
                    Normal      = Get-ObjectPropertyValue -Object $props -Name 'UninstallString'
                    KeyPath     = $item.PSPath
                    KeyName     = $item.PSChildName
                    Scope       = $scope
                    ProductCode = $code
                }
            }
            catch {
                Write-RegistryLog WARN "Failed to evaluate known uninstall key '$kp': $($_.Exception.Message)"
            }
        }
    }

    return $found
}

function Get-LiongardAuthHeader {
    param(
        [string]$ApiTokenKey,
        [string]$ApiTokenSecret
    )

    $token = "$ApiTokenKey`:$ApiTokenSecret"
    $bytes = [System.Text.Encoding]::UTF8.GetBytes($token)
    $encoded = [System.Convert]::ToBase64String($bytes)
    return @{
        'X-ROAR-API-KEY' = $encoded
        'User-Agent'     = 'LiongardAgentInstallerEXE/1.1'
    }
}

function Mask-SecretValue {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) { return '' }
    if ($Value.Length -le 8) { return ('*' * $Value.Length) }

    $prefix = $Value.Substring(0, 4)
    $suffix = $Value.Substring($Value.Length - 4, 4)
    return "$prefix****$suffix"
}

function Mask-ProxyValue {
    param([string]$Value)

    if ([string]::IsNullOrWhiteSpace($Value)) { return '<empty>' }

    if ($Value -match '^(?<scheme>https?://)(?<user>[^:/@]+)(:(?<pass>[^@]*))?@(?<host>.+)$') {
        return ("{0}{1}:****@{2}" -f $Matches['scheme'], $Matches['user'], $Matches['host'])
    }

    return $Value
}

