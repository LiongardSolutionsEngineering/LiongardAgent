function Section-GoRuntime {
    $agentLog = Join-Path $Script:Staging 'evidence\logs\agent.log'
    if (-not (Test-Path $agentLog)) { Write-Report '  (no collected agent.log to parse)'; return }
    try {
        $lines = Get-Content -LiteralPath $agentLog -ErrorAction SilentlyContinue
        $lastStart = ''
        $lastHb = ''
        $lastOutcome = 'none'      # tracks the MOST RECENT heartbeat attempt (lines are chronological)
        $errClasses = @{}
        $statusCodes = @{}
        $panic = $false
        $missingUrl = $false
        foreach ($ln in $lines) {
            if ($ln -match '"msg":"Starting agent') { $lastStart = $ln }
            if ($ln -match 'Heartbeat response') {
                if ($ln -match '"ts":"([^"]+)"') { $lastHb = $matches[1] } else { $lastHb = 'seen' }
                $lastOutcome = 'success'
            }
            if ($ln -match 'Error sending heartbeat') {
                $cls = 'other'
                if ($ln -match 'no such host|lookup') { $cls = 'DNS' }
                elseif ($ln -match 'x509:|certificate signed by|tls:') { $cls = 'TLS' }
                elseif ($ln -match 'proxyconnect') { $cls = 'PROXY' }
                elseif ($ln -match 'context deadline exceeded|Timeout exceeded') { $cls = 'TIMEOUT' }
                elseif ($ln -match 'connection refused|no route to host') { $cls = 'REFUSED' }
                if (-not $errClasses.ContainsKey($cls)) { $errClasses[$cls] = 0 }
                $errClasses[$cls]++
                $lastOutcome = 'error'
            }
            if ($ln -match 'Error in heartbeat response' -and $ln -match '"status_code":(\d+)') {
                $sc = $matches[1]; if (-not $statusCodes.ContainsKey($sc)) { $statusCodes[$sc] = 0 }; $statusCodes[$sc]++
                $lastOutcome = 'error'
            }
            if ($ln -match 'Invalid proxy URL') { $panic = $true }
            if ($ln -match 'MISSING-URL-ENV-VAR') { $missingUrl = $true }
        }
        Add-Fact 'HB.LastSuccess' $lastHb
        Add-Fact 'HB.LastOutcome' $lastOutcome
        Add-Fact 'HB.CurrentlyFailing' ($lastOutcome -eq 'error')
        Add-Fact 'HB.ErrorClasses' $errClasses
        Add-Fact 'HB.StatusCodes' $statusCodes
        Add-Fact 'HB.ProxyPanic' $panic
        Add-Fact 'HB.MissingUrl' $missingUrl
        Write-Report ("Last 'Starting agent': " + $(if ($lastStart) { 'yes' } else { 'none in window' }))
        Write-Report ("Last heartbeat success: " + $(if ($lastHb) { $lastHb } else { 'NONE in collected window' }))
        Write-Report ("Most recent heartbeat attempt outcome: " + $lastOutcome)
        if ($errClasses.Count) { Write-Report ("Heartbeat error classes (historical in window): " + (($errClasses.GetEnumerator() | ForEach-Object { $_.Key + '=' + $_.Value }) -join ', ')) }
        if ($statusCodes.Count) { Write-Report ("Heartbeat HTTP status codes: " + (($statusCodes.GetEnumerator() | ForEach-Object { $_.Key + '=' + $_.Value }) -join ', ')) }
        if ($panic) { Write-Report ("  DETECTED: 'Invalid proxy URL' panic (bad GLOBAL_AGENT_HTTP_PROXY -> crash loop)") }
        if ($missingUrl) { Write-Report ("  DETECTED: MISSING-URL-ENV-VAR (URL not injected)") }
    } catch { Write-Report ("  agent.log parse error: " + $_.Exception.Message) }
}

