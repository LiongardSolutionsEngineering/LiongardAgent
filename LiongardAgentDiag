# LiongardAgent-Diag.ps1 - Liongard Windows Agent one-shot support diagnostic: collects everything support needs in ONE run when the agent is "installed but the service will not start / no heartbeat" (commonly a code-signing trust problem on hardened Windows Server).
# STRICTLY READ-ONLY: changes nothing on the machine; only reads state and writes a diagnostic bundle to your Desktop.
# Output: a folder on your Desktop containing the diagnostic .zip and a readable _report.txt; email the .zip to Liongard support.
# Privacy: secrets are redacted from collected files, but the bundle can still contain system/network details, so treat it as sensitive.
# HOW TO RUN (elevated Windows PowerShell recommended): powershell -NoProfile -ExecutionPolicy Bypass -File .\LiongardAgent-Diag.ps1
# If script execution is locked by group policy, ask support for the escalation steps documented alongside this script.
# Company: Liongard, Inc.

[CmdletBinding()]
param(
    [string] $OutputDir,            # override output location (default: Desktop chain)
    [int]    $MaxLogTailLines = 60000,
    [switch] $SkipNetwork          # skip the network connectivity section
)

# ===== SAVE LOCATION: leave as 'Desktop' to use your Desktop (the default), or set any folder, e.g. 'C:\Temp' or '\\fileserver\share\LiongardDiag' =====
$OutputLocation = 'Desktop'
# Plumbing (normally no need to edit): 'Desktop' or blank uses the auto-pick chain below; any other value is used as an explicit folder, created if missing. The -OutputDir <path> command-line parameter still overrides everything.
$Script:DefaultOutputDir = if ($OutputLocation -and $OutputLocation -ne 'Desktop') { $OutputLocation } else { '' }
$Script:OutputDirCandidates = @(
    (Join-Path $env:USERPROFILE 'Desktop'),    # 1. the user's Desktop (default)
    $env:USERPROFILE,                          # 2. the user's profile root
    $PSScriptRoot,                             # 3. the folder the script was run from
    $env:TEMP                                  # 4. temp (last resort)
)
# ============================================================================

# --- 0. Bootstrap: constants, capability flags, PS7 relaunch ---
$Script:DiagVersion = '2.0.0'
$Script:StartedUtc  = (Get-Date).ToUniversalTime()
$Script:StartedLoc  = Get-Date
# Timing via DateTime deltas (CLM-safe); [System.Diagnostics.Stopwatch]::StartNew() is a static method call that is BLOCKED under Constrained Language Mode.
function Get-ElapsedSec { param([datetime]$Since) try { return ((Get-Date) - $Since).TotalSeconds } catch { return 0 } }

# Relaunch under Windows PowerShell 5.1 if we were started under PowerShell 7 (Core).
if ($PSVersionTable.PSEdition -eq 'Core' -and -not $env:LG_DIAG_RELAUNCHED) {
    $winPs = Join-Path $env:WINDIR 'System32\WindowsPowerShell\v1.0\powershell.exe'
    if (Test-Path $winPs) {
        $env:LG_DIAG_RELAUNCHED = '1'
        $selfPath = $PSCommandPath
        if (-not $selfPath) { $selfPath = $MyInvocation.MyCommand.Path }
        if ($selfPath) {
            & $winPs -NoProfile -ExecutionPolicy Bypass -File $selfPath @PSBoundParameters
            exit $LASTEXITCODE
        }
    }
    # No powershell.exe (PS7-only image): fall through and run under pwsh with a warning.
}

# Language mode: anything other than FullLanguage means Add-Type / New-Object on arbitrary .NET types are restricted (WDAC/AppLocker Constrained Language Mode).
$Script:LangMode = $ExecutionContext.SessionState.LanguageMode
$Script:IsCLM    = ($Script:LangMode -ne 'FullLanguage')

# Can we compile a P/Invoke type? Catches both CLM (parse block) and WDAC/AppLocker blocking of csc.exe / the temp DLL load (throws even in FullLanguage).
$Script:CanCompile = $false
try {
    Add-Type -TypeDefinition 'public class LgDiagProbe { public static int Ping() { return 1; } }' -ErrorAction Stop
    if ([LgDiagProbe]::Ping() -eq 1) { $Script:CanCompile = $true }
} catch { $Script:CanCompile = $false }

# Elevation. FullLanguage: definitive WindowsPrincipal check. CLM: whoami /priv heuristic (admin-only privileges are absent from a filtered/non-elevated token).
$Script:IsAdmin      = $false
$Script:ElevCheckKind = 'unknown'
try {
    if (-not $Script:IsCLM) {
        $id  = [System.Security.Principal.WindowsIdentity]::GetCurrent()
        $pr  = New-Object System.Security.Principal.WindowsPrincipal($id)
        $Script:IsAdmin = $pr.IsInRole([System.Security.Principal.WindowsBuiltinRole]::Administrator)
        $Script:ElevCheckKind = 'WindowsPrincipal'
    } else {
        $priv = (whoami /priv) 2>$null | Out-String
        $Script:IsAdmin = ($priv -match 'SeTakeOwnershipPrivilege' -or $priv -match 'SeDebugPrivilege' -or $priv -match 'SeLoadDriverPrivilege')
        $Script:ElevCheckKind = 'whoami-priv-heuristic'
    }
} catch { $Script:IsAdmin = $false }

# --- Shared state ---
$Script:Facts        = @{}
$Script:Findings     = @()     # verdict records
$Script:Errors       = @()     # trapped section errors
$Script:Manifest     = @()     # collected-file manifest rows
$Script:ReportBuffer = @()
$Script:SectionTimes = @{}
$Script:ReportPath   = $null   # set once staging exists

# Known Trusted Signing anchors (verified against LiongardAgentSVC.csproj metadata)
$Script:ExpectedSubject = 'Liongard, Inc.'
$Script:ExpectedRoot    = 'Microsoft Identity Verification Root Certificate Authority 2020'
$Script:CodeSigningEku  = '1.3.6.1.5.5.7.3.3'
$Script:UpgradeCode     = '088da427-038f-4cad-a5a6-29acd707ff61'

# --- Helpers ---
function Get-Stamp { return (Get-Date -Format 'yyyy-MM-dd HH:mm:ss') }

function Write-Report {
    param([string] $Text = '')
    $Script:ReportBuffer += $Text
    try { Write-Host $Text } catch {}
}

function Flush-Report {
    if ($Script:ReportPath) {
        try { Set-Content -LiteralPath $Script:ReportPath -Value $Script:ReportBuffer -Encoding ASCII -ErrorAction SilentlyContinue } catch {}
    }
}

function Add-Fact { param([string]$Key, $Value) $Script:Facts[$Key] = $Value }
function Get-FactVal { param([string]$Key) if ($Script:Facts.ContainsKey($Key)) { return $Script:Facts[$Key] } return $null }

function Add-ManifestRow {
    param([string]$RelPath, [string]$Flags = '')
    $full = Join-Path $Script:Staging $RelPath
    $bytes = ''
    $sha = ''
    try {
        if (Test-Path -LiteralPath $full) {
            $it = Get-Item -LiteralPath $full -ErrorAction SilentlyContinue
            if ($it -and -not $it.PSIsContainer) {
                $bytes = $it.Length
                try { $sha = (Get-FileHash -LiteralPath $full -Algorithm SHA256 -ErrorAction SilentlyContinue).Hash } catch {}
            }
        }
    } catch {}
    $Script:Manifest += @{ Path = $RelPath; Bytes = $bytes; Sha256 = $sha; Flags = $Flags }
}

function Get-MaskedSecret {
    param([string]$Value, [int]$Keep = 4)
    if ([string]::IsNullOrEmpty($Value)) { return '(empty)' }
    $len = $Value.Length
    if ($len -le ($Keep * 2)) { return (('*' * $len) + " (len=$len)") }
    return ($Value.Substring(0, $Keep) + '...' + $Value.Substring($len - $Keep) + " (len=$len)")
}

function Test-DirWritable {
    param([string]$Path)
    if (-not $Path) { return $false }
    try {
        if (-not (Test-Path -LiteralPath $Path)) { return $false }
        $probe = Join-Path $Path (".lgdiag_" + (Get-Date -Format 'HHmmssfff'))
        Set-Content -LiteralPath $probe -Value 'x' -ErrorAction Stop
        Remove-Item -LiteralPath $probe -Force -ErrorAction SilentlyContinue
        return $true
    } catch { return $false }
}

function Resolve-OutputDir {
    # Explicit choices (the -OutputDir parameter, then the configured $DefaultOutputDir) win, and may be created if missing - that is deliberate operator intent.
    foreach ($explicit in @($OutputDir, $Script:DefaultOutputDir)) {
        if ($explicit) {
            if (-not (Test-Path -LiteralPath $explicit)) {
                try { New-Item -ItemType Directory -Path $explicit -Force -ErrorAction Stop | Out-Null } catch {}
            }
            if (Test-DirWritable $explicit) { return $explicit }
        }
    }
    # Automatic fallbacks ($OutputDirCandidates, top of script). READ-ONLY: these are used only if they already exist and are writable; never created here.
    foreach ($c in $Script:OutputDirCandidates) {
        if (-not $c) { continue }
        if (Test-DirWritable $c) { return $c }
    }
    return $env:TEMP
}

function Get-TimeBudgetSeconds { return [int](Get-ElapsedSec $Script:StartedLoc) }

# Run a scriptblock (typically an external tool) in a child job with a hard timeout; cmdlet-only => safe in Constrained Language Mode. Returns output lines (array).
function Invoke-Timed {
    param([scriptblock]$Script, [object[]]$ArgList = @(), [int]$TimeoutSec = 20)
    $out = @()
    try {
        $j = Start-Job -ScriptBlock $Script -ArgumentList $ArgList -ErrorAction Stop
    } catch {
        return @("[Invoke-Timed could not start job: $($_.Exception.Message)]")
    }
    try {
        if (Wait-Job $j -Timeout $TimeoutSec) {
            $out = @(Receive-Job $j 2>&1 | ForEach-Object { "$_" })
        } else {
            Stop-Job $j -ErrorAction SilentlyContinue
            $out = @("[TIMEOUT after ${TimeoutSec}s]")
        }
    } catch {
        $out = @("[Invoke-Timed error: $($_.Exception.Message)]")
    } finally {
        Remove-Job $j -Force -ErrorAction SilentlyContinue
    }
    return $out
}

# --- Redaction --------------------------------------------------------------
$Script:RedactionRules = @(
    @{ Id='R1';  Profiles=@('config'); Pattern='(?i)(key="(?:ROAR_ACCESS_KEY_ID|ROAR_SECRET_ACCESS_KEY|AWS_ACCESS_KEY_ID|AWS_SECRET_ACCESS_KEY|AWS_SESSION_TOKEN)"\s+value=")[^"]*(")'; Replacement='${1}[REDACTED]${2}' },
    # R1b: generic XML-config backstop - any key name containing secret/password/token/accesskey
    @{ Id='R1b'; Profiles=@('config'); Pattern='(?i)(key="[^"]*(?:secret|password|token|accesskey|access_key)[^"]*"\s+value=")[^"]*(")'; Replacement='${1}[REDACTED]${2}' },
    # R2a: MSI Property()/command-line format  NAME=value  or  NAME: value  (coarse line-tail; over-redaction is safe)
    @{ Id='R2a'; Profiles=@('msilog'); Pattern='(?i)((?:LiongardAccessKey|LiongardAccessSecret|RoarAccessKey|RoarAccessSecret|LIONGARDAGENTSERVICEPASSWORD|LIONGARDAGENTSERVICEUSERNAME)["'']?\s*[:=]\s*).+$'; Replacement='${1}[REDACTED-LINE-TAIL]' },
    # R2b: WiX Burn engine format  (Initializing|Setting) string variable 'NAME' to value 'VALUE'
    @{ Id='R2b'; Profiles=@('msilog'); Pattern='(?i)(variable ''(?:LiongardAccessKey|LiongardAccessSecret|RoarAccessKey|RoarAccessSecret|LIONGARDAGENTSERVICEPASSWORD|ProxyUrl)'' to value '')[^'']*('')'; Replacement='${1}[REDACTED]${2}' },
    # R2c: MSI PROPERTY CHANGE format  (Adding|Modifying) NAME property. Its value is 'VALUE'.
    @{ Id='R2c'; Profiles=@('msilog'); Pattern='(?i)((?:Adding|Modifying) (?:LIONGARDACCESSKEY|LIONGARDACCESSSECRET|ROARACCESSKEY|ROARACCESSSECRET|LIONGARDAGENTSERVICEPASSWORD) property\. Its value is '')[^'']*('')'; Replacement='${1}[REDACTED]${2}' },
    @{ Id='R3';  Profiles=@('generic'); Pattern='(?i)(X-ROAR-AGENT-KEY\s*[:=]\s*)\S+'; Replacement='${1}[REDACTED]' },
    @{ Id='R4';  Profiles=@('generic'); Pattern='(?i)(authorization\s*[:=]\s*)(bearer\s+|basic\s+)?\S+'; Replacement='${1}${2}[REDACTED]' },
    # R5: asset-inventory / network-discovery PII in the Go zap JSON logs (agent.log + service stdout)
    @{ Id='R5';  Profiles=@('agentlog'); Pattern='(?i)("(?:request_body|response_body|device_ip|device_hostname|device_mac|device_id|device_serial|device_tcp_ports_open|device_tcp_ports_closed)"\s*:\s*)("(?:[^"\\]|\\.)*"|\[[^\]]*\]|[^,}\s]+)'; Replacement='${1}"[REDACTED-asset-inventory]"' },
    @{ Id='R6';  Profiles=@('generic'); Pattern='(?i)\b(password|passwd|secret|api[_-]?key|access[_-]?key|token)\b(["'']?\s*[:=]\s*["'']?)(?!\[REDACTED)([^\s"'',;]{4,})'; Replacement='${1}${2}[REDACTED]' },
    @{ Id='R7';  Profiles=@('generic'); Pattern='\b(AGC[A-Za-z0-9$!@#%^&*()_+\-=]{4,})'; Replacement='[REDACTED-KEY]' },
    # R8: credentials embedded in a URL userinfo  scheme://user:pass@host
    @{ Id='R8';  Profiles=@('generic'); Pattern='(?i)(://)[^/@\s:]+:[^/@\s]+@'; Replacement='${1}[REDACTED]@' }
)

function Invoke-Redaction {
    param([string]$Line, [string]$Profile)
    $result = $Line
    foreach ($rule in $Script:RedactionRules) {
        if (($rule.Profiles -contains $Profile) -or ($rule.Profiles -contains 'generic')) {
            $result = $result -replace $rule.Pattern, $rule.Replacement
        }
    }
    return $result
}

# Copy a text file into the bundle with redaction, optionally tail-capped by lines; never uses Get-Content -Raw (agent.log can be 200MB). Returns a flags string.
function Copy-RedactedFile {
    param(
        [string]$Source,
        [string]$DestRel,          # relative to staging
        [string]$Profile = 'generic',
        [int]$TailLines = 0        # 0 = whole file
    )
    $dest = Join-Path $Script:Staging $DestRel
    $flags = ''
    try {
        if (-not (Test-Path -LiteralPath $Source)) {
            Add-ManifestRow $DestRel "[MISSING: source not found]"
            return '[MISSING]'
        }
        $item = Get-Item -LiteralPath $Source -ErrorAction Stop
        $origBytes = $item.Length
        $origHash = ''
        try { $origHash = (Get-FileHash -LiteralPath $Source -Algorithm SHA256 -ErrorAction SilentlyContinue).Hash } catch {}

        # Stream through the redactor (no growing PS array: agent.log can be huge). Counter lives in script scope so the pipeline ForEach block can update it.
        $Script:RedCounter = 0
        $truncated = $false

        if ($TailLines -gt 0) {
            $lines = Get-Content -LiteralPath $Source -Tail $TailLines -ErrorAction Stop
            if ($null -eq $lines) { $lines = @() }
            if (@($lines).Count -ge $TailLines) { $truncated = $true }
            $banner = @()
            if ($truncated) {
                $banner = @(
                    ('######## TRUNCATED BY LiongardAgent-Diag v' + $Script:DiagVersion + ' ########'),
                    ('Original file: ' + $Source + '  (' + $origBytes + ' bytes)'),
                    ('Kept: LAST ' + $TailLines + ' lines. SHA256 of ORIGINAL full file: ' + $origHash),
                    '#############################################################'
                )
            }
            Set-Content -LiteralPath $dest -Value $banner -Encoding ASCII -ErrorAction Stop
            $lines | ForEach-Object {
                $r = Invoke-Redaction -Line ([string]$_) -Profile $Profile
                if ($r -cne ([string]$_)) { $Script:RedCounter++ }
                $r
            } | Add-Content -LiteralPath $dest -Encoding ASCII -ErrorAction Stop
        } else {
            Set-Content -LiteralPath $dest -Value @() -Encoding ASCII -ErrorAction Stop
            Get-Content -LiteralPath $Source -ErrorAction Stop | ForEach-Object {
                $r = Invoke-Redaction -Line ([string]$_) -Profile $Profile
                if ($r -cne ([string]$_)) { $Script:RedCounter++ }
                $r
            } | Add-Content -LiteralPath $dest -Encoding ASCII -ErrorAction Stop
        }
        $redCount = $Script:RedCounter
        if ($truncated) { $flags = "[TRUNCATED last $TailLines lines] " }
        $flags += "[REDACTED n=$redCount]"
        Add-ManifestRow $DestRel $flags
        return $flags
    } catch {
        $msg = $_.Exception.Message
        try { Set-Content -LiteralPath $dest -Value @("[COLLECTION FAILED: $msg]") -Encoding ASCII -ErrorAction SilentlyContinue } catch {}
        Add-ManifestRow $DestRel "[ERROR: $msg]"
        return "[ERROR: $msg]"
    }
}

# Section wrapper: isolates failures, times, flushes the partial report.
function Invoke-Section {
    param([string]$Id, [string]$Index, [string]$Title, [scriptblock]$Body)
    Write-Report ''
    Write-Report ('================================================================================')
    Write-Report ("SECTION $Id - $Title")
    Write-Report ('================================================================================')
    $secStart = Get-Date
    $status = 'OK'
    $prevEap = $ErrorActionPreference
    try {
        $ErrorActionPreference = 'Stop'
        & $Body
    } catch {
        $status = 'FAILED'
        $rec = "[$Id $Title] $($_.Exception.GetType().Name): $($_.Exception.Message)"
        $Script:Errors += $rec
        Write-Report ("  !! SECTION ERROR (diagnostic continues): " + $_.Exception.Message)
    } finally {
        $ErrorActionPreference = $prevEap
        $secEl = Get-ElapsedSec $secStart
        $Script:SectionTimes[$Id] = $secEl
        Flush-Report
        $line = ("[$Index] {0,-34} {1} ({2:N1}s)" -f $Title, $status, $secEl)
        try { Write-Host $line } catch {}
    }
}

function Add-Finding {
    param(
        [string]$Class, [string]$Confidence, [string]$Title,
        [string[]]$Found, [string]$Meaning, [string]$Fix
    )
    $Script:Findings += @{
        Class = $Class; Confidence = $Confidence; Title = $Title;
        Found = $Found; Meaning = $Meaning; Fix = $Fix
    }
}

# --- Section bodies ---

function Section-System {
    try {
        $os = Get-CimInstance Win32_OperatingSystem -ErrorAction Stop
        Write-Report ("OS              : " + $os.Caption + "  (" + $os.Version + ", build " + $os.BuildNumber + ")")
        Write-Report ("Architecture    : " + $os.OSArchitecture)
        Write-Report ("Install type    : " + $(if ($os.ProductType -eq 1) { 'Workstation' } else { 'Server' }))
        Add-Fact 'OS.ProductType' $os.ProductType
        Add-Fact 'OS.Caption' $os.Caption
        $boot = $os.LastBootUpTime
        Write-Report ("Last boot       : " + $boot)
    } catch { Write-Report ("OS info error: " + $_.Exception.Message) }

    $tzName = ''
    try { $tzName = (Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\TimeZoneInformation' -Name TimeZoneKeyName -ErrorAction SilentlyContinue).TimeZoneKeyName } catch {}
    Write-Report ("Time zone       : " + $tzName)
    Write-Report ("Local time      : " + $Script:StartedLoc + "   (UTC " + $Script:StartedUtc + ")")

    # Clock skew via w32tm (timed).
    try {
        $w32 = Invoke-Timed -TimeoutSec 10 -Script { & w32tm /query /status 2>&1 }
        $skew = $null
        foreach ($l in $w32) {
            if ($l -match 'Phase Offset\s*:\s*([\-0-9\.]+)s') { $skew = [double]$matches[1] }
        }
        if ($null -ne $skew) {
            Add-Fact 'Time.SkewSeconds' $skew
            Write-Report ("Clock offset    : " + $skew + "s (from w32tm)")
        } else {
            Write-Report ("Clock offset    : (w32tm did not report a phase offset)")
        }
        $wf = Join-Path $Script:Staging 'evidence\system\w32tm-status.txt'
        Set-Content -LiteralPath $wf -Value $w32 -Encoding ASCII -ErrorAction SilentlyContinue
        Add-ManifestRow 'evidence\system\w32tm-status.txt'
    } catch { Write-Report ("w32tm error: " + $_.Exception.Message) }

    # FIPS / SChannel / .NET / proxy — plain registry reads (HKLM read = CLM-safe).
    $sys = @()
    try {
        $fips = (Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\Lsa\FipsAlgorithmPolicy' -Name Enabled -ErrorAction SilentlyContinue).Enabled
        Add-Fact 'Crypto.FIPS' $fips
        $sys += "FIPS policy Enabled            : $fips"
    } catch {}
    try {
        $net = (Get-ItemProperty 'HKLM:\SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full' -Name Release -ErrorAction SilentlyContinue).Release
        $sys += ".NET Framework Release DWORD   : $net"
    } catch {}
    try {
        # Machine-scope env via registry (CLM-safe; avoids the [Environment] static call).
        $proxyEnv = (Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Environment' -Name GLOBAL_AGENT_HTTP_PROXY -ErrorAction SilentlyContinue).GLOBAL_AGENT_HTTP_PROXY
        Add-Fact 'Proxy.GlobalAgent' ([bool]$proxyEnv)
        $proxyDisp = $(if ($proxyEnv) { Invoke-Redaction -Line ([string]$proxyEnv) -Profile 'generic' } else { '(not set)' })
        $sys += "GLOBAL_AGENT_HTTP_PROXY (machine): " + $proxyDisp
    } catch {}
    try {
        $sch = 'HKLM:\SYSTEM\CurrentControlSet\Control\SecurityProviders\SCHANNEL\Protocols'
        if (Test-Path $sch) {
            $sys += "SCHANNEL protocol overrides present under: $sch (see crypto-policy.txt)"
            $dump = Get-ChildItem -Path $sch -Recurse -ErrorAction SilentlyContinue | ForEach-Object { $_.Name + ' -> ' + ((Get-ItemProperty $_.PSPath -ErrorAction SilentlyContinue | Out-String).Trim()) }
            Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\system\crypto-policy.txt') -Value $dump -Encoding ASCII -ErrorAction SilentlyContinue
            Add-ManifestRow 'evidence\system\crypto-policy.txt'
        }
    } catch {}
    # Pending reboot markers
    try {
        $pfro = (Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager' -Name PendingFileRenameOperations -ErrorAction SilentlyContinue).PendingFileRenameOperations
        $pending = (Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing\RebootPending') -or `
                   (Test-Path 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired') -or `
                   ([bool]$pfro)
        $sys += "Pending reboot                 : $pending"
    } catch {}
    foreach ($s in $sys) { Write-Report ("  " + $s) }
    try {
        $osLines = @()
        $osLines += ('Generated: ' + (Get-Stamp))
        $osLines += ('Computer : ' + $env:COMPUTERNAME)
        try { $osLines += ('OS       : ' + $os.Caption + ' ' + $os.Version + ' build ' + $os.BuildNumber + ' ' + $os.OSArchitecture) } catch {}
        $osLines += ('TimeZone : ' + $tzName)
        $osLines += ('LocalTime: ' + $Script:StartedLoc + '  (UTC ' + $Script:StartedUtc + ')')
        $osLines += $sys
        Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\system\os-time-env.txt') -Value $osLines -Encoding ASCII -ErrorAction SilentlyContinue
        Add-ManifestRow 'evidence\system\os-time-env.txt'
    } catch {}
}

function Section-FindInstall {
    $installDir = $null
    $workDir = $null
    $sources = @()

    # 1. Registry INSTALLLOCATION (both views)
    foreach ($k in @('HKLM:\SOFTWARE\WOW6432Node\Liongard\RoarAgent','HKLM:\SOFTWARE\Liongard\RoarAgent')) {
        try {
            $p = Get-ItemProperty -LiteralPath $k -ErrorAction SilentlyContinue
            if ($p -and $p.INSTALLLOCATION) { $sources += "registry($k)=" + $p.INSTALLLOCATION; if (-not $installDir) { $installDir = $p.INSTALLLOCATION } }
        } catch {}
    }
    # 2. Service ImagePath dir
    try {
        $svcImg = (Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Services\roaragent.exe' -Name ImagePath -ErrorAction SilentlyContinue).ImagePath
        if ($svcImg) {
            $clean = $svcImg.Trim('"')
            $dir = Split-Path $clean -Parent
            $sources += "service.ImagePath=" + $dir
            if (-not $installDir) { $installDir = $dir }
        }
    } catch {}
    # 3. Default path
    $default = 'C:\Program Files (x86)\LiongardInc\LiongardAgent'
    if (-not $installDir -and (Test-Path $default)) { $installDir = $default; $sources += "default=" + $default }

    if ($installDir) { $installDir = $installDir.TrimEnd('\') }
    Add-Fact 'Install.Dir' $installDir
    Add-Fact 'Install.Found' ([bool]($installDir -and (Test-Path $installDir)))

    Write-Report ("Install dir     : " + $(if ($installDir) { $installDir } else { '(NOT FOUND)' }))
    foreach ($s in $sources) { Write-Report ("  source: " + $s) }

    # Path mismatch warning
    $distinct = @($sources | ForEach-Object { ($_ -split '=',2)[1] } | Where-Object { $_ } | ForEach-Object { $_.TrimEnd('\') } | Sort-Object -Unique)
    if ($distinct.Count -gt 1) {
        Add-Fact 'Install.PathMismatch' $true
        Write-Report ("  WARNING: install path sources disagree: " + ($distinct -join ' | '))
    }

    # WORK_DIR (from config) resolved separately - AgentSVCLog + Go logs live there.
    $workDir = $installDir
    try {
        $cfg = Join-Path $installDir 'appsettings-override.config'
        if ($installDir -and (Test-Path $cfg)) {
            $raw = Get-Content -LiteralPath $cfg -ErrorAction SilentlyContinue
            foreach ($l in $raw) {
                if ($l -match 'key="WORK_DIR"\s+value="([^"]*)"') { $workDir = $matches[1].TrimEnd('\') }
            }
        }
    } catch {}
    Add-Fact 'Install.WorkDir' $workDir
    Write-Report ("Work dir        : " + $(if ($workDir) { $workDir } else { '(unknown)' }))

    # Binary inventory + SHA256 + version resources
    if ($installDir -and (Test-Path $installDir)) {
        $inv = @()
        foreach ($exe in @('LiongardAgent.exe','LiongardAgentSVC.exe','LiongardAgentUpdater.exe')) {
            $path = Join-Path $installDir $exe
            if (Test-Path $path) {
                $it = Get-Item $path
                $sha = ''
                try { $sha = (Get-FileHash $path -Algorithm SHA256).Hash } catch {}
                $ver = ''
                try { $ver = $it.VersionInfo.ProductVersion } catch {}
                $inv += ("{0,-28} ver={1,-12} {2} bytes  mtime={3}" -f $exe, $ver, $it.Length, $it.LastWriteTime)
                $inv += ("    SHA256=" + $sha)
                Write-Report ("  " + $exe + "  ver=" + $ver)
                if ($exe -eq 'LiongardAgent.exe') { Add-Fact 'Install.GoAgentPath' $path; Add-Fact 'Install.GoAgentVersion' $ver }
                if ($exe -eq 'LiongardAgentSVC.exe') { Add-Fact 'Install.SvcPath' $path }
            } else {
                $inv += ("MISSING: " + $exe)
                Write-Report ("  MISSING: " + $exe)
            }
        }
        Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\install\binary-inventory.txt') -Value $inv -Encoding ASCII -ErrorAction SilentlyContinue
        Add-ManifestRow 'evidence\install\binary-inventory.txt'
    } else {
        Write-Report ("  (agent not installed - downstream sections will be limited)")
    }
}

function Section-Service {
    $out = @()
    try {
        $svc = Get-CimInstance Win32_Service -Filter "Name='roaragent.exe'" -ErrorAction SilentlyContinue
        if (-not $svc) { $svc = Get-CimInstance Win32_Service -ErrorAction SilentlyContinue | Where-Object { $_.Name -match 'roaragent|LiongardAgentSVC' -or $_.DisplayName -match 'Liongard' } | Select-Object -First 1 }
        if ($svc) {
            Write-Report ("Service         : " + $svc.Name + " (" + $svc.DisplayName + ")")
            Write-Report ("  State/Start   : " + $svc.State + " / " + $svc.StartMode)
            Write-Report ("  Run as        : " + $svc.StartName)
            Add-Fact 'Svc.State' $svc.State
            Add-Fact 'Svc.Account' $svc.StartName
            $out += ("Name=" + $svc.Name); $out += ("DisplayName=" + $svc.DisplayName)
            $out += ("State=" + $svc.State); $out += ("StartMode=" + $svc.StartMode)
            $out += ("StartName=" + $svc.StartName); $out += ("PathName=" + $svc.PathName)
        } else {
            Write-Report ("Service         : NOT FOUND")
            Add-Fact 'Svc.State' 'NotInstalled'
            $out += 'Service roaragent.exe not found.'
        }
    } catch { Write-Report ("Service query error: " + $_.Exception.Message) }

    # Raw failure actions
    try {
        $fa = Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Services\roaragent.exe' -ErrorAction SilentlyContinue
        if ($fa) { $out += ("FailureActions(raw present)=" + [bool]$fa.FailureActions); $out += ("ImagePath=" + $fa.ImagePath) }
    } catch {}

    # Processes
    $goRunning = $false
    try {
        $go = Get-Process -Name 'LiongardAgent' -ErrorAction SilentlyContinue
        $sv = Get-Process -Name 'LiongardAgentSVC','roaragent' -ErrorAction SilentlyContinue
        $goRunning = [bool]$go
        Write-Report ("  Go agent proc : " + [bool]$go + "    service proc: " + [bool]$sv)
        if ($go) { foreach ($g in $go) { $out += ("proc LiongardAgent pid=" + $g.Id + " start=" + $g.StartTime) } }
    } catch {}
    Add-Fact 'Proc.GoAgentRunning' $goRunning

    Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\registry\service-roaragent.txt') -Value $out -Encoding ASCII -ErrorAction SilentlyContinue
    Add-ManifestRow 'evidence\registry\service-roaragent.txt'
}

function Section-Config {
    $installDir = Get-FactVal 'Install.Dir'
    if (-not $installDir) { Write-Report '  (no install dir - skipped)'; return }

    # DEVELOPMENT_MODE from the service exe.config (verbatim copy - no secrets there)
    $svcCfg = Join-Path $installDir 'LiongardAgentSVC.exe.config'
    if (Test-Path $svcCfg) {
        try {
            $raw = Get-Content -LiteralPath $svcCfg -ErrorAction SilentlyContinue
            $dev = $false
            foreach ($l in $raw) { if ($l -match 'key="DEVELOPMENT_MODE"\s+value="([^"]*)"') { $dev = ($matches[1] -match '^(?i:true|1)$') } }
            Add-Fact 'Config.DevMode' $dev
            Write-Report ("DEVELOPMENT_MODE: " + $dev)
            Copy-Item -LiteralPath $svcCfg -Destination (Join-Path $Script:Staging 'evidence\config\LiongardAgentSVC.exe.config') -ErrorAction SilentlyContinue
            Add-ManifestRow 'evidence\config\LiongardAgentSVC.exe.config'
        } catch {}
    }

    # appsettings-override.config: required keys, pre-migration secret presence
    $cfg = Join-Path $installDir 'appsettings-override.config'
    if (Test-Path $cfg) {
        try {
            $raw = Get-Content -LiteralPath $cfg -ErrorAction SilentlyContinue
            $keys = @{}
            foreach ($l in $raw) {
                if ($l -match 'key="([^"]+)"\s+value="([^"]*)"') { $keys[$matches[1]] = $matches[2] }
            }
            $required = @('URL','AGENT_ID','AGENT_NAME','AGENT_UID','RESPONSE_QUEUE','WORK_DIR')
            $missing = @()
            foreach ($r in $required) { if (-not $keys.ContainsKey($r) -or [string]::IsNullOrEmpty($keys[$r])) { $missing += $r } }
            Add-Fact 'Config.MissingKeys' $missing
            if ($keys.ContainsKey('URL')) { Add-Fact 'Config.URL' $keys['URL'] }
            $preSecrets = @('ROAR_ACCESS_KEY_ID','ROAR_SECRET_ACCESS_KEY','AWS_ACCESS_KEY_ID','AWS_SECRET_ACCESS_KEY') | Where-Object { $keys.ContainsKey($_) }
            Add-Fact 'Config.PreMigrationSecretsPresent' ([bool]$preSecrets)

            Write-Report ("Config URL      : " + $(if ($keys.ContainsKey('URL')) { $keys['URL'] } else { '(missing)' }))
            Write-Report ("Missing keys    : " + $(if ($missing.Count) { $missing -join ', ' } else { '(none)' }))
            Write-Report ("Pre-migration plaintext creds in config: " + $(if ($preSecrets) { 'PRESENT (migration incomplete): ' + ($preSecrets -join ',') } else { 'ABSENT (migration completed)' }))

            # Redacted copy
            $redLines = @()
            foreach ($l in $raw) { $redLines += (Invoke-Redaction -Line ([string]$l) -Profile 'config') }
            Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\config\appsettings-override.config') -Value $redLines -Encoding ASCII -ErrorAction SilentlyContinue
            Add-ManifestRow 'evidence\config\appsettings-override.config' '[REDACTED config secrets]'
        } catch { Write-Report ("  config parse error: " + $_.Exception.Message) }
    } else {
        Write-Report ("appsettings-override.config: NOT FOUND (registration may not have completed)")
        Add-Fact 'Config.MissingFile' $true
    }
}

function Section-Registry {
    $out = @()
    # Seed to $false so Class C fires when the key is missing entirely (upgrade to $true if found).
    Add-Fact 'Reg.AgentKeyPresent' $false
    foreach ($k in @('HKLM:\SOFTWARE\WOW6432Node\Liongard\RoarAgent','HKLM:\SOFTWARE\Liongard\RoarAgent')) {
        try {
            $p = Get-ItemProperty -LiteralPath $k -ErrorAction SilentlyContinue
            if ($p) {
                $out += ("[$k]")
                foreach ($prop in $p.PSObject.Properties) {
                    if ($prop.Name -like 'PS*') { continue }
                    $val = $prop.Value
                    if ($prop.Name -eq 'AgentKey') { $val = Get-MaskedSecret ([string]$val) }
                    $out += ("  " + $prop.Name + " = " + $val)
                    if ($prop.Name -eq 'AgentKey') { Add-Fact 'Reg.AgentKeyPresent' ([bool]$prop.Value) }
                    if ($prop.Name -eq 'ProductVersion') { Add-Fact 'Reg.ProductVersion' $prop.Value }
                }
            }
        } catch {}
    }
    foreach ($k in @('HKLM:\SOFTWARE\WOW6432Node\Liongard\LiongardAgent\MachineID','HKLM:\SOFTWARE\Liongard\LiongardAgent\MachineID')) {
        try {
            $p = Get-ItemProperty -LiteralPath $k -ErrorAction SilentlyContinue
            if ($p -and $p.AgentGuid) { $out += ("[$k] AgentGuid = " + $p.AgentGuid); Add-Fact 'Reg.AgentGuid' $p.AgentGuid }
        } catch {}
    }
    Write-Report ("Registry AgentKey present : " + (Get-FactVal 'Reg.AgentKeyPresent'))
    Write-Report ("Registry ProductVersion   : " + (Get-FactVal 'Reg.ProductVersion'))
    Write-Report ("Registry AgentGuid        : " + (Get-FactVal 'Reg.AgentGuid'))

    # ARP scan
    $arp = @()
    foreach ($base in @('HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall','HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall')) {
        try {
            Get-ChildItem $base -ErrorAction SilentlyContinue | ForEach-Object {
                $d = Get-ItemProperty $_.PSPath -ErrorAction SilentlyContinue
                if ($d.DisplayName -match 'Liongard') {
                    $arp += ("DisplayName=" + $d.DisplayName + " Version=" + $d.DisplayVersion + " Publisher=" + $d.Publisher)
                    $arp += ("  QuietUninstall=" + $d.QuietUninstallString)
                }
            }
        } catch {}
    }
    if ($arp.Count) { Write-Report ("ARP entries     : " + $arp.Count + " Liongard entry(ies) found") }
    $out += ''; $out += '--- ARP ---'; $out += $arp
    Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\registry\liongard-keys.txt') -Value $out -Encoding ASCII -ErrorAction SilentlyContinue
    Add-ManifestRow 'evidence\registry\liongard-keys.txt'
    Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\install\arp-uninstall.txt') -Value $arp -Encoding ASCII -ErrorAction SilentlyContinue
    Add-ManifestRow 'evidence\install\arp-uninstall.txt'
}

# HRESULT map for WinVerifyTrust
$Script:HResultMap = @{
    '0'          = 'SUCCESS - this check would PASS'
    '2148204800' = 'TRUST_E_NOSIGNATURE (0x800B0100) - file is not signed / signature unreadable'
    '2148204545' = 'TRUST_E_PROVIDER_UNKNOWN (0x800B0001)'
    '2148204548' = 'TRUST_E_SUBJECT_NOT_TRUSTED (0x800B0004) - subject failed verification'
    '2148204809' = 'CERT_E_UNTRUSTEDROOT (0x800B0109) - chain ends in an UNTRUSTED root'
    '2148204810' = 'CERT_E_CHAINING (0x800B010A) - chain could not be built (partial chain)'
    '2148204812' = 'CERT_E_REVOKED (0x800B010C) - certificate was revoked'
    '2148204814' = 'CERT_E_REVOCATION_FAILURE (0x800B010E) - revocation check could not complete'
    '2148204801' = 'CERT_E_EXPIRED (0x800B0101) - signing cert expired'
    '2148204817' = 'TRUST_E_EXPLICIT_DISTRUST (0x800B0111) - cert is in the Untrusted/Disallowed store'
    '2148081683' = 'CRYPT_E_REVOCATION_OFFLINE (0x80092013) - revocation servers UNREACHABLE'
    '2148081709' = 'CRYPT_E_NO_REVOCATION_CHECK (0x8009202D) - no revocation check performed'
    '2148098064' = 'TRUST_E_BAD_DIGEST (0x80096010) - file digest mismatch (corrupt/tampered)'
    '2148098053' = 'TRUST_E_TIME_STAMP (0x80096005) - timestamp countersignature invalid'
}
function Resolve-HResult {
    param([uint32]$Code)
    $key = ([int64]$Code).ToString()
    if ($Script:HResultMap.ContainsKey($key)) { return $Script:HResultMap[$key] }
    return ('0x{0:X8} (unmapped - look up this HRESULT)' -f $Code)
}

$Script:WinTrustSource = @'
using System;
using System.Runtime.InteropServices;
public static class LgWinTrust {
    [StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
    class WinTrustFileInfo {
        UInt32 StructSize = (UInt32)Marshal.SizeOf(typeof(WinTrustFileInfo));
        IntPtr pszFilePath; IntPtr hFile = IntPtr.Zero; IntPtr pgKnownSubject = IntPtr.Zero;
        public WinTrustFileInfo(String p) { pszFilePath = Marshal.StringToCoTaskMemAuto(p); }
    }
    [StructLayout(LayoutKind.Sequential, CharSet = CharSet.Unicode)]
    class WinTrustData {
        UInt32 StructSize = (UInt32)Marshal.SizeOf(typeof(WinTrustData));
        IntPtr PolicyCallbackData = IntPtr.Zero;
        IntPtr SIPClientData = IntPtr.Zero;
        uint UIChoice = 2;              // None
        uint RevocationChecks = 0;      // None (field; provflags drive revocation)
        uint UnionChoice = 1;           // File
        IntPtr FileInfoPtr;
        uint StateAction = 0;           // Ignore
        IntPtr StateData = IntPtr.Zero;
        String URLReference = null;
        public uint ProvFlags;
        uint UIContext = 0;             // Execute
        public WinTrustData(WinTrustFileInfo fi, uint provFlags) {
            ProvFlags = provFlags;
            FileInfoPtr = Marshal.AllocCoTaskMem(Marshal.SizeOf(typeof(WinTrustFileInfo)));
            Marshal.StructureToPtr(fi, FileInfoPtr, false);
        }
    }
    [DllImport("wintrust.dll", ExactSpelling = true, SetLastError = false, CharSet = CharSet.Unicode)]
    static extern uint WinVerifyTrust(IntPtr hwnd, [MarshalAs(UnmanagedType.LPStruct)] Guid pgActionID, WinTrustData pWVTData);
    static readonly Guid ActionV2 = new Guid("00AAC56B-CD44-11d0-8CC2-00C04FC295EE");
    static readonly IntPtr INVALID_HANDLE_VALUE = new IntPtr(-1);
    public static uint Verify(string file, uint provFlags) {
        var fi = new WinTrustFileInfo(file);
        var wtd = new WinTrustData(fi, provFlags);
        return WinVerifyTrust(INVALID_HANDLE_VALUE, ActionV2, wtd);
    }
}
'@

function Section-SignatureGate {
    $exe = Get-FactVal 'Install.GoAgentPath'
    $out = @()
    if (-not $exe -or -not (Test-Path $exe)) {
        Write-Report '  (LiongardAgent.exe not found - gate check skipped)'
        Add-Fact 'Gate.Fidelity' 'None'
        return
    }

    $fidelity = 'Minimal'

    # --- WinVerifyTrust replica (Full fidelity) ---
    if ($Script:CanCompile) {
        try {
            Add-Type -TypeDefinition $Script:WinTrustSource -ErrorAction Stop
            $fidelity = 'Full'
            $osMajor = [Environment]::OSVersion.Version.Major
            $md = 0x2000  # DisableMD2andMD4 (service sets this on Win7SP1+ / all modern)
            $variants = @(
                @{ Name='NoRevocation'; Flags=([uint32](0x10 -bor $md)) },
                @{ Name='CacheOnly';    Flags=([uint32](0x80 -bor $md -bor 0x1000)) },
                @{ Name='Exact';        Flags=([uint32](0x80 -bor $md)) }
            )
            $results = @{}
            foreach ($v in $variants) {
                # Exact runs last; note if it is slow (egress blackhole = evidence).
                $sw = [System.Diagnostics.Stopwatch]::StartNew()
                $code = [LgWinTrust]::Verify($exe, $v.Flags)
                $sw.Stop()
                $results[$v.Name] = $code
                $interp = Resolve-HResult -Code $code
                $line = ("WinVerifyTrust [{0,-12}] flags=0x{1:X4} -> 0x{2:X8}  {3}  ({4:N1}s)" -f $v.Name, $v.Flags, $code, $interp, $sw.Elapsed.TotalSeconds)
                Write-Report ("  " + $line)
                $out += $line
            }
            Add-Fact 'Gate.WinTrust.Exact' ([int64]$results['Exact'])
            Add-Fact 'Gate.WinTrust.CacheOnly' ([int64]$results['CacheOnly'])
            Add-Fact 'Gate.WinTrust.NoRev' ([int64]$results['NoRevocation'])
            if ($results['Exact'] -ne 0 -and $results['CacheOnly'] -eq 0) {
                Write-Report ("  => Trust chain is OK; gate fails ONLY on online revocation (egress blocked). [Class B]")
            }
        } catch {
            Write-Report ("  WinVerifyTrust replica unavailable: " + $_.Exception.Message)
            $fidelity = 'Reduced'
        }
    } else {
        $fidelity = $(if ($Script:IsCLM) { 'Minimal' } else { 'Reduced' })
        Write-Report ("  P/Invoke replica SKIPPED (compiler/language mode). Using cmdlet fallbacks.")
    }

    # --- Get-AuthenticodeSignature (cmdlet = real WinVerifyTrust, always available) ---
    try {
        $sig = Get-AuthenticodeSignature -LiteralPath $exe -ErrorAction Stop
        Write-Report ("Authenticode    : " + $sig.Status + "  (" + $sig.StatusMessage + ")")
        Add-Fact 'Gate.Authenticode' ([string]$sig.Status)
        $out += ("Authenticode status: " + $sig.Status + " - " + $sig.StatusMessage)
        if ($sig.SignerCertificate) {
            $out += ("Signer: " + $sig.SignerCertificate.Subject)
            $out += ("Issuer: " + $sig.SignerCertificate.Issuer)
            $out += ("Valid : " + $sig.SignerCertificate.NotBefore + " -> " + $sig.SignerCertificate.NotAfter)
        }
    } catch { Write-Report ("  Authenticode check error: " + $_.Exception.Message) }

    # --- IsLionGardCert replica (FullLanguage only; certutil fallback in CLM) ---
    if (-not $Script:IsCLM) {
        try {
            $raw = [System.Security.Cryptography.X509Certificates.X509Certificate]::CreateFromSignedFile($exe)
            $cert = New-Object System.Security.Cryptography.X509Certificates.X509Certificate2($raw)
            $subj = $cert.GetNameInfo([System.Security.Cryptography.X509Certificates.X509NameType]::SimpleName, $false)
            $subjOk = ($subj -and ($subj.Trim().ToLower() -eq $Script:ExpectedSubject.ToLower()))
            Add-Fact 'Gate.Cert.SubjectOk' $subjOk
            $out += ("Subject SimpleName: '" + $subj + "'  (expected '" + $Script:ExpectedSubject + "') -> " + $subjOk)

            $ekuOk = $false
            foreach ($ext in $cert.Extensions) {
                if ($ext -is [System.Security.Cryptography.X509Certificates.X509EnhancedKeyUsageExtension]) {
                    foreach ($oid in $ext.EnhancedKeyUsages) { if ($oid.Value -eq $Script:CodeSigningEku) { $ekuOk = $true } }
                }
            }
            Add-Fact 'Gate.Cert.EkuOk' $ekuOk
            $out += ("Code Signing EKU (" + $Script:CodeSigningEku + "): " + $ekuOk)

            $chain = New-Object System.Security.Cryptography.X509Certificates.X509Chain
            $chain.ChainPolicy.RevocationMode = 'NoCheck'
            $chain.ChainPolicy.VerificationFlags = 'IgnoreNotTimeValid, IgnoreCtlNotTimeValid'
            $built = $chain.Build($cert)
            Add-Fact 'Gate.Cert.ChainBuilt' $built
            $rootName = ''
            $pkiHosts = @()
            if ($chain.ChainElements.Count -gt 0) {
                $rootName = $chain.ChainElements[$chain.ChainElements.Count-1].Certificate.GetNameInfo([System.Security.Cryptography.X509Certificates.X509NameType]::SimpleName, $false)
                for ($i=0; $i -lt $chain.ChainElements.Count; $i++) {
                    $el = $chain.ChainElements[$i]
                    $out += ("  chain[$i] " + $el.Certificate.Subject)
                    # Harvest AIA/CDP URLs from extensions
                    foreach ($ext in $el.Certificate.Extensions) {
                        if ($ext.Oid.Value -eq '1.3.6.1.5.5.7.1.1' -or $ext.Oid.Value -eq '2.5.29.31') {
                            $fmt = $ext.Format($false)
                            foreach ($m in [regex]::Matches($fmt, 'https?://[^\s\)]+')) { $pkiHosts += $m.Value }
                        }
                    }
                }
            }
            foreach ($cs in $chain.ChainStatus) { if ($cs.Status -ne 'NotTimeValid') { $out += ("  chainstatus: " + $cs.Status + " - " + $cs.StatusInformation.Trim()) } }
            $rootOk = ($rootName -eq $Script:ExpectedRoot)
            Add-Fact 'Gate.Cert.RootSubject' $rootName
            Add-Fact 'Gate.Cert.RootOk' $rootOk
            Add-Fact 'Gate.PkiHosts' (@($pkiHosts | Sort-Object -Unique))
            Write-Report ("Cert chain root : '" + $rootName + "'  matches expected: " + $rootOk)
            $out += ("Chain built=" + $built + " root='" + $rootName + "' rootOk=" + $rootOk)
        } catch {
            Write-Report ("  IsLionGardCert replica error: " + $_.Exception.Message)
        }
    } else {
        # CLM chain fallback: export signer cert + certutil -urlfetch -verify
        try {
            $sig2 = Get-AuthenticodeSignature -LiteralPath $exe -ErrorAction SilentlyContinue
            if ($sig2 -and $sig2.SignerCertificate) {
                $cerPath = Join-Path $Script:Staging 'evidence\certs\signer.cer'
                Export-Certificate -Cert $sig2.SignerCertificate -FilePath $cerPath -Type CERT -Force -ErrorAction SilentlyContinue | Out-Null
                $cu = Invoke-Timed -TimeoutSec 20 -ArgList @($cerPath) -Script { param($c) & certutil -f -urlfetch -verify $c 2>&1 }
                Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\certs\certutil-verify.txt') -Value $cu -Encoding ASCII -ErrorAction SilentlyContinue
                Add-ManifestRow 'evidence\certs\certutil-verify.txt'
                $joined = ($cu -join "`n")
                if ($joined -match 'UntrustedRoot|CERT_E_UNTRUSTEDROOT') { Add-Fact 'Gate.Cert.RootOk' $false }
                if ($joined -match 'offline|CRYPT_E_REVOCATION_OFFLINE') { Add-Fact 'Gate.WinTrust.RevocationOffline' $true }
                Write-Report ("  certutil -verify captured (see certs/certutil-verify.txt)")
            }
        } catch { Write-Report ("  certutil fallback error: " + $_.Exception.Message) }
    }

    Add-Fact 'Gate.Fidelity' $fidelity
    Write-Report ("Gate fidelity   : " + $fidelity)
    Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\certs\gate-replica.txt') -Value $out -Encoding ASCII -ErrorAction SilentlyContinue
    Add-ManifestRow 'evidence\certs\gate-replica.txt'
}

function Section-CertEnvironment {
    $out = @()
    $rootInRoot = $false
    $rootInDisallowed = $false
    try {
        $rootInRoot = [bool](Get-ChildItem Cert:\LocalMachine\Root -ErrorAction SilentlyContinue | Where-Object { $_.Subject -match [regex]::Escape($Script:ExpectedRoot) })
    } catch {}
    try {
        $rootInDisallowed = [bool](Get-ChildItem Cert:\LocalMachine\Disallowed -ErrorAction SilentlyContinue | Where-Object { $_.Subject -match [regex]::Escape($Script:ExpectedRoot) })
    } catch {}
    Add-Fact 'Cert.RootInStore' $rootInRoot
    Add-Fact 'Cert.RootInDisallowed' $rootInDisallowed
    Write-Report ("MS Trusted Signing root in LocalMachine\Root      : " + $rootInRoot)
    Write-Report ("MS Trusted Signing root in LocalMachine\Disallowed: " + $rootInDisallowed)
    $out += ("RootInRoot=" + $rootInRoot); $out += ("RootInDisallowed=" + $rootInDisallowed)

    try {
        $ar = (Get-ItemProperty 'HKLM:\SOFTWARE\Policies\Microsoft\SystemCertificates\AuthRoot' -Name DisableRootAutoUpdate -ErrorAction SilentlyContinue).DisableRootAutoUpdate
        Add-Fact 'Cert.DisableRootAutoUpdate' $ar
        Write-Report ("DisableRootAutoUpdate policy: " + $(if ($ar -eq 1) { '1 (auto root update DISABLED - hardened)' } else { '0/unset (allowed)' }))
        $out += ("DisableRootAutoUpdate=" + $ar)
    } catch {}
    Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\certs\store-scan.txt') -Value $out -Encoding ASCII -ErrorAction SilentlyContinue
    Add-ManifestRow 'evidence\certs\store-scan.txt'
}

function Section-CredentialPath {
