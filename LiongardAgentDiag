    } catch {}

    # C# service log(s) - collect all rolled, full (each ~11MB max); use the 'agentlog' profile because AgentSVCLog captures the Go agent's stdout (same JSON stream as agent.log) and so must get the asset-inventory PII redaction (R5), not just 'generic'.
    foreach ($pat in @('AgentSVCLog.txt','AgentSVCLog.0.txt','AgentSVCLog.1.txt','AgentSVCLog.2.txt')) {
