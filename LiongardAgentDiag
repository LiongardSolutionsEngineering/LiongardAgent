function Section-EventLogs {
    if (-not $Script:IsAdmin) { Write-Report '  [PARTIAL: some event data needs elevation]' }
    $evDir = Join-Path $Script:Staging 'evidence\eventlog'

    # Binary export (best evidence)
    try {
        $evtx = Join-Path $evDir 'LiongardAgentLog.evtx'
        $r = Invoke-Timed -TimeoutSec 30 -ArgList @($evtx) -Script { param($p) & wevtutil epl LiongardAgentLog $p /ow:true 2>&1 }
        if (Test-Path $evtx) { Add-ManifestRow 'evidence\eventlog\LiongardAgentLog.evtx' } else { Add-ManifestRow 'evidence\eventlog\LiongardAgentLog.evtx' ('[MISSING: ' + ($r -join ' ') + ']') }
    } catch {}

    # Text dump + pattern match
    $patterns = @(
        'A valid signature was not found for the agent process',
        'Agent process does not appear to have been signed by Liongard',
        'Certificate does not chain to the expected Microsoft Trusted Signing root',
        'Certificate is missing the Code Signing EKU',
        'Certificate subject identity does not match the expected Liongard signing identity',
        'Failed to fetch agent key from registry',
        'Failed to fetch agent credential from credential manager',
        'Error in process start',
        'Restarting Liongard Agent Service',
        'Running in development mode - skipping signature verification',
        'Agent executable file does not exist at path',
        'Liongard Agent Successfully Started'
    )
    try {
        $events = Get-WinEvent -LogName 'LiongardAgentLog' -MaxEvents 500 -ErrorAction Stop | Sort-Object TimeCreated
        $txt = @()
        foreach ($e in $events) {
            $msg = Invoke-Redaction -Line ($e.Message -replace '\r?\n',' | ') -Profile 'generic'
            $txt += ('[{0:yyyy-MM-dd HH:mm:ss}] [{1}] [{2}] {3}' -f $e.TimeCreated, $e.LevelDisplayName, $e.ProviderName, $msg)
        }
        Set-Content -LiteralPath (Join-Path $evDir 'LiongardAgentLog_last500.txt') -Value $txt -Encoding ASCII -ErrorAction SilentlyContinue
        Add-ManifestRow 'evidence\eventlog\LiongardAgentLog_last500.txt'

        Write-Report ("Event pattern matches (last 500 events):")
        foreach ($p in $patterns) {
            $hits = @($events | Where-Object { $_.Message -match [regex]::Escape($p) })
            if ($hits.Count -gt 0) {
                $last = ($hits[-1].TimeCreated).ToString('yyyy-MM-dd HH:mm:ss')
                Write-Report ("  [{0,4}x, last {1}] {2}" -f $hits.Count, $last, $p)
                Add-Fact ('Evt.' + ($p -replace '[^A-Za-z]','')) $hits.Count
            }
        }
        # crash-loop metric (24h)
        $since = (Get-Date).AddHours(-24)
        $restart = @($events | Where-Object { $_.TimeCreated -gt $since -and $_.Message -match 'Restarting Liongard Agent Service' })
        Add-Fact 'Evt.RestartCount24h' $restart.Count
        Write-Report ("Restarts (crash-loop metric, 24h): " + $restart.Count)
        Add-Fact 'Evt.LogPresent' $true
    } catch {
        Write-Report ("  LiongardAgentLog: " + $_.Exception.Message)
        Add-Fact 'Evt.LogPresent' $false
    }

    # Filtered Application/System (by ID+provider - locale independent)
    try {
        $sys = Get-WinEvent -FilterHashtable @{ LogName='System'; StartTime=(Get-Date).AddDays(-7); Id=@(7000,7009,7011,7031,7034) } -ErrorAction SilentlyContinue |
            Where-Object { $_.Message -match 'roaragent|Liongard' } |
            ForEach-Object { ('[{0:yyyy-MM-dd HH:mm:ss}] id={1} {2}' -f $_.TimeCreated, $_.Id, (Invoke-Redaction -Line ($_.Message -replace '\r?\n',' | ') -Profile 'generic')) }
        if ($sys) { Set-Content -LiteralPath (Join-Path $evDir 'System_7d_filtered.txt') -Value $sys -Encoding ASCII -ErrorAction SilentlyContinue; Add-ManifestRow 'evidence\eventlog\System_7d_filtered.txt' }
    } catch {}
    try {
        $app = Get-WinEvent -FilterHashtable @{ LogName='Application'; StartTime=(Get-Date).AddDays(-7); Level=@(1,2,3) } -ErrorAction SilentlyContinue |
            Where-Object { $_.Message -match 'Liongard|roaragent' } |
            ForEach-Object { ('[{0:yyyy-MM-dd HH:mm:ss}] {1} {2}' -f $_.TimeCreated, $_.ProviderName, (Invoke-Redaction -Line ($_.Message -replace '\r?\n',' | ') -Profile 'generic')) }
        if ($app) { Set-Content -LiteralPath (Join-Path $evDir 'Application_7d_filtered.txt') -Value $app -Encoding ASCII -ErrorAction SilentlyContinue; Add-ManifestRow 'evidence\eventlog\Application_7d_filtered.txt' }
    } catch {}
}

function Section-CollectLogs {
