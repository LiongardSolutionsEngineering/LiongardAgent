# TCP test - FullLanguage batch BeginConnect; CLM uses Test-NetConnection jobs.
function Test-TcpTargets {
    param([array]$Targets, [int]$DeadlineSec = 5)
    $results = @{}
    if (-not $Script:IsCLM) {
        $pending = @()
        foreach ($t in $Targets) {
            try {
                $c = New-Object System.Net.Sockets.TcpClient
                $ar = $c.BeginConnect($t.Host, $t.Port, $null, $null)
                $pending += @{ Key = ($t.Host + ':' + $t.Port); Client = $c; Ar = $ar }
            } catch { $results[($t.Host + ':' + $t.Port)] = 'ERROR' }
        }
        $deadline = (Get-Date).AddSeconds($DeadlineSec)
        foreach ($p in $pending) {
            $remMs = [int]([Math]::Max(0, ($deadline - (Get-Date)).TotalMilliseconds))
            $ok = $false
            try {
                if ($p.Ar.AsyncWaitHandle.WaitOne($remMs)) { $p.Client.EndConnect($p.Ar); $ok = $p.Client.Connected }
            } catch { $ok = $false }
            $results[$p.Key] = $(if ($ok) { 'OPEN' } else { 'blocked/closed' })
            try { $p.Client.Close() } catch {}
        }
    } else {
        foreach ($t in $Targets) {
            $out = Invoke-Timed -TimeoutSec 6 -ArgList @($t.Host, $t.Port) -Script { param($h,$p) (Test-NetConnection $h -Port $p -WarningAction SilentlyContinue).TcpTestSucceeded }
            $results[($t.Host + ':' + $t.Port)] = $(if ("$out" -match 'True') { 'OPEN' } else { 'blocked/closed' })
        }
    }
    return $results
}

function Section-Connectivity {
    if ($SkipNetwork) { Write-Report '  (skipped via -SkipNetwork)'; return }
    $url = Get-FactVal 'Config.URL'
    $targets = @()
    if ($url) {
        $targets += @{ Host = ('api.' + $url); Port = 443 }
        $targets += @{ Host = ('timon.' + $url); Port = 443 }
    }
    $targets += @{ Host = 'agents.static.liongard.com'; Port = 443 }
    $targets += @{ Host = 'sqs.us-west-2.amazonaws.com'; Port = 443 }
    $targets += @{ Host = 'ctldl.windowsupdate.com'; Port = 443 }
    $targets += @{ Host = 'ctldl.windowsupdate.com'; Port = 80 }
    # PKI hosts harvested from the signer chain
    $pki = Get-FactVal 'Gate.PkiHosts'
    if ($pki) { foreach ($h in $pki) { try { $u = [uri]$h; $targets += @{ Host = $u.Host; Port = $(if ($u.Scheme -eq 'https') {443} else {80}) } } catch {} } }

    $res = Test-TcpTargets -Targets $targets -DeadlineSec 5
    $out = @()
    foreach ($k in ($res.Keys | Sort-Object)) {
        Write-Report ("  " + ("{0,-45} {1}" -f $k, $res[$k]))
        $out += ("{0,-45} {1}" -f $k, $res[$k])
        Add-Fact ('Net.' + ($k -replace '[^A-Za-z0-9]','_')) $res[$k]
    }

    # DNS distinction + served-chain capture for api.<URL>
    if ($url -and -not $Script:IsCLM) {
        $apiHost = 'api.' + $url
        try {
            $ips = [System.Net.Dns]::GetHostAddresses($apiHost)
            $out += ("DNS " + $apiHost + " -> " + (($ips | ForEach-Object { $_.IPAddressToString }) -join ', '))
        } catch { $out += ("DNS " + $apiHost + " FAILED: " + $_.Exception.Message); Add-Fact 'Net.ApiDnsFailed' $true }

        try {
            $tcp = New-Object System.Net.Sockets.TcpClient
            $ar = $tcp.BeginConnect($apiHost, 443, $null, $null)
            if ($ar.AsyncWaitHandle.WaitOne(5000) -and $tcp.Connected) {
                $tcp.EndConnect($ar)
                $captured = @()
                $cb = [System.Net.Security.RemoteCertificateValidationCallback]{
                    param($sender, $cert, $chain, $errors)
                    if ($chain) { foreach ($el in $chain.ChainElements) { $script:__capHost += ,($el.Certificate.Subject + ' <= ' + $el.Certificate.Issuer) } }
                    return $true
                }
                $script:__capHost = @()
                $ssl = New-Object System.Net.Security.SslStream($tcp.GetStream(), $false, $cb)
                # Pin TLS 1.2 - the parameterless AuthenticateAsClient() uses SslProtocols.Default, which on stock .NET Framework 4.x omits 1.2 and fails the handshake.
                try { $ssl.AuthenticateAsClient($apiHost, $null, [System.Security.Authentication.SslProtocols]'Tls12', $false) }
                catch { $ssl.AuthenticateAsClient($apiHost) }
                $out += ("--- TLS served chain for " + $apiHost + " ---")
                $out += $script:__capHost
                $issuers = ($script:__capHost -join ' ')
                if ($issuers -match '(?i)fortinet|fortigate|palo alto|zscaler|sophos|watchguard|sonicwall|netskope|SSL Inspection|Deep Packet') {
                    Add-Fact 'Net.SslInspection' $true
                    $out += ('  !! Possible SSL-inspection middlebox (issuer pattern matched)')
                }
                $ssl.Close()
            }
            $tcp.Close()
        } catch { $out += ("TLS capture for " + $apiHost + " error: " + $_.Exception.Message) }
    }

    # winhttp proxy
    $wp = Invoke-Timed -TimeoutSec 8 -Script { & netsh winhttp show proxy 2>&1 }
    $out += '--- netsh winhttp show proxy ---'; $out += $wp

    Set-Content -LiteralPath (Join-Path $Script:Staging 'evidence\network\connectivity.txt') -Value $out -Encoding ASCII -ErrorAction SilentlyContinue
    Add-ManifestRow 'evidence\network\connectivity.txt'
}

# --- Verdict engine ---
function Invoke-VerdictEngine {
    $f = $Script:Facts
    $fid = Get-FactVal 'Gate.Fidelity'

    # Health gate: the launch-failure classes (A/B/C/D-fingerprint/E/F) describe an agent that is NOT working NOW, so if the Go agent is running AND its most recent heartbeat attempt SUCCEEDED, those classes must NOT fire on stale/historical log entries.
    $agentRunning = ((Get-FactVal 'Proc.GoAgentRunning') -eq $true)
    $hbLastOutcome = Get-FactVal 'HB.LastOutcome'
    $hbFailingNow  = ((Get-FactVal 'HB.CurrentlyFailing') -eq $true)
    $agentHealthy  = ($agentRunning -and ($hbLastOutcome -eq 'success'))
    $launchFailing = (-not $agentHealthy)

    # A - untrusted root / partial chain
    $exact = Get-FactVal 'Gate.WinTrust.Exact'
    $norev = Get-FactVal 'Gate.WinTrust.NoRev'
    $rootInStore = Get-FactVal 'Cert.RootInStore'
    $rootDisallowed = Get-FactVal 'Cert.RootInDisallowed'
    $rootOk = Get-FactVal 'Gate.Cert.RootOk'
    $aEvidence = @()
    if ($norev -ne $null -and ($norev -eq 2148204809 -or $norev -eq 2148204810)) { $aEvidence += ("WinVerifyTrust no-revocation variant -> " + (Resolve-HResult ([uint32]$norev))) }
    if ($rootOk -eq $false) { $aEvidence += "Signer chain does not terminate in the expected Microsoft Trusted Signing root." }
    if ($rootInStore -eq $false) { $aEvidence += "MS Trusted Signing root is ABSENT from LocalMachine\Root." }
    if ($rootDisallowed -eq $true) { $aEvidence += "MS Trusted Signing root is in the Disallowed (explicit distrust) store." }
    if ($aEvidence.Count -and $launchFailing) {
        $conf = $(if ($fid -eq 'Full') { 'HIGH' } else { 'MEDIUM' })
        $fix = 'Trust the Microsoft Trusted Signing root: enable Automatic Root Update, allow ctldl.windowsupdate.com, or GPO-import the "Microsoft Identity Verification Root Certificate Authority 2020" root.'
        if ($rootDisallowed -eq $true) { $conf = 'HIGH'; $fix = 'Remove the explicit distrust entry: the MS Trusted Signing root is in the Disallowed store. ' + $fix }
        Add-Finding -Class 'A' -Confidence $conf -Title 'Signature gate fails: untrusted / unbuildable certificate chain' -Found $aEvidence -Meaning 'The C# service cannot validate the agent binary signature, so it never launches the Go agent -> no heartbeat.' -Fix $fix
    }

    # B - revocation offline
    $cacheOnly = Get-FactVal 'Gate.WinTrust.CacheOnly'
    $bEvidence = @()
    if ($exact -ne $null -and $exact -ne 0 -and $cacheOnly -eq 0) { $bEvidence += ("WinVerifyTrust Exact=" + (Resolve-HResult ([uint32]$exact)) + " but CacheOnly=SUCCESS (matrix delta).") }
    if ($exact -ne $null -and ($exact -eq 2148081683 -or $exact -eq 2148204814 -or $exact -eq 2148081709)) { $bEvidence += ("WinVerifyTrust Exact -> " + (Resolve-HResult ([uint32]$exact))) }
    if ((Get-FactVal 'Gate.WinTrust.RevocationOffline') -eq $true) { $bEvidence += 'certutil reported revocation offline.' }
    if ($bEvidence.Count -and $launchFailing) {
        Add-Finding -Class 'B' -Confidence $(if ($fid -eq 'Full') { 'HIGH' } else { 'MEDIUM' }) -Title 'Signature gate fails: online revocation check cannot reach CRL/OCSP' -Found $bEvidence -Meaning 'The service gate forces ONLINE revocation checking of the chain (ProvFlags exclude-root). The trust chain itself is fine, but the box cannot reach the revocation servers, so the gate fails at every service (re)start.' -Fix 'Allow outbound to the CRL/OCSP/AIA hosts listed in certs/gate-replica.txt and to ctldl.windowsupdate.com (required at every start, not once).'
    }

    # C - credential / service account
    $cEvidence = @()
    if (Get-FactVal 'Evt.Failedtofetchagentcredentialfromcredentialmanager') { $cEvidence += 'Event log: "Failed to fetch agent credential from credential manager."' }
    if (Get-FactVal 'Evt.Failedtofetchagentkeyfromregistry') { $cEvidence += 'Event log: "Failed to fetch agent key from registry".' }
    if ((Get-FactVal 'Reg.AgentKeyPresent') -eq $false) { $cEvidence += 'Registry AgentKey value is absent.' }
    if ((Get-FactVal 'Cred.CustomServiceAccount') -eq $true) { $cEvidence += ('Service runs as a custom account (' + (Get-FactVal 'Svc.Account') + '), which reads a different credential store than the one written.') }
    if ($cEvidence.Count -and $launchFailing) {
        Add-Finding -Class 'C' -Confidence $(if (Get-FactVal 'Evt.Failedtofetchagentcredentialfromcredentialmanager') { 'HIGH' } else { 'MEDIUM' }) -Title 'Agent launch fails: credential / service-account problem' -Found $cEvidence -Meaning 'The service passes the signature gate but cannot retrieve the agent key/secret, so it aborts launching the Go agent (mimics the cert symptom).' -Fix 'Re-register/reinstall to rewrite the credential; if a custom service account is required, ensure the credential exists in THAT account''s store.'
    }

    # D - missing config keys
    $missing = Get-FactVal 'Config.MissingKeys'
    $dEvidence = @()
    if ($missing -and @($missing).Count -gt 0) { $dEvidence += ('appsettings-override.config is missing required keys: ' + (@($missing) -join ', ')) }
    if ((Get-FactVal 'Config.MissingFile') -eq $true) { $dEvidence += 'appsettings-override.config not found.' }
    $errStart = Get-FactVal 'Evt.Errorinprocessstart'
    if ($errStart -and $errStart -gt 0 -and -not (Get-FactVal 'Evt.Avalidsignaturewasnotfoundfortheagentprocess')) { $dEvidence += ("Recurring 'Error in process start' events (" + $errStart + ") without signature-failure events (NullRef fingerprint of a missing config key).") }
    if ($dEvidence.Count -and $launchFailing) {
        Add-Finding -Class 'D' -Confidence $(if ($missing -and @($missing).Count) { 'HIGH' } else { 'MEDIUM' }) -Title 'Agent launch fails: configuration missing/incomplete' -Found $dEvidence -Meaning 'The service throws building the child environment (a missing appsettings key), so the Go agent never launches.' -Fix 'Repair/reinstall the agent to regenerate appsettings-override.config with all required keys.'
    }

    # E - gate passes, heartbeat fails
    $errClasses = Get-FactVal 'HB.ErrorClasses'
    $statusCodes = Get-FactVal 'HB.StatusCodes'
    if ($hbFailingNow -and $errClasses -and @($errClasses.Keys).Count) {
        foreach ($k in $errClasses.Keys) {
            $sub = ''
            $fix = ''
            switch ($k) {
                'DNS'     { $sub = 'E1 DNS resolution failing'; $fix = 'Fix DNS / allow name resolution for the platform host.' }
                'TLS'     { $sub = 'E2 TLS trust failure'; $fix = 'A TLS-inspecting middlebox or missing CA. The Go agent trusts the Windows store; ensure the served CA chain is trusted there.' ; if ((Get-FactVal 'Net.SslInspection') -eq $true) { $sub = 'E2 TLS failure + SSL-inspection middlebox detected'; } }
                'PROXY'   { $sub = 'E3 proxy failure'; $fix = 'Fix or remove GLOBAL_AGENT_HTTP_PROXY.' }
                'TIMEOUT' { $sub = 'E4 connection timeout'; $fix = 'Open outbound 443 to the platform host.' }
                'REFUSED' { $sub = 'E5 connection refused/unreachable'; $fix = 'Check firewall/routing to the platform host.' }
                default   { $sub = 'E heartbeat error (other)'; $fix = 'See agent.log error strings.' }
            }
            Add-Finding -Class 'E' -Confidence 'HIGH' -Title ('Gate passes but heartbeat fails: ' + $sub) -Found @(('agent.log: ' + $errClasses[$k] + ' "Error sending heartbeat" of class ' + $k)) -Meaning 'The Go agent runs but cannot reach the platform.' -Fix $fix
        }
    }
    if ((Get-FactVal 'HB.ProxyPanic') -eq $true -and -not $agentRunning) {
        Add-Finding -Class 'E' -Confidence 'HIGH' -Title 'Gate passes but agent crash-loops: invalid proxy URL' -Found @('agent.log: "Invalid proxy URL" panic; cross-check RestartCount24h=' + (Get-FactVal 'Evt.RestartCount24h')) -Meaning 'A malformed GLOBAL_AGENT_HTTP_PROXY makes the Go agent panic on startup; the service relaunches it every 60s.' -Fix 'Correct or clear the GLOBAL_AGENT_HTTP_PROXY environment variable.'
    }
    if ($hbFailingNow -and $statusCodes -and ($statusCodes.ContainsKey('401') -or $statusCodes.ContainsKey('403'))) {
        Add-Finding -Class 'E' -Confidence 'HIGH' -Title 'Gate passes but heartbeat is rejected (401/403)' -Found @('agent.log heartbeat status codes: ' + (($statusCodes.GetEnumerator() | ForEach-Object { $_.Key + '=' + $_.Value }) -join ', ')) -Meaning 'The agent credential is invalid/rejected by the platform (deleted agent or credential mismatch).' -Fix 'Verify the agent record on the platform and re-register if needed.'
    }

    # F - AppLocker/WDAC/AV block
    $fEvidence = @()
    if ((Get-FactVal 'Blk.CodeIntegrityHits') -gt 0) { $fEvidence += ((Get-FactVal 'Blk.CodeIntegrityHits').ToString() + ' CodeIntegrity/AppLocker block events reference Liongard paths.') }
    if ((Get-FactVal 'Blk.DefenderLiongard') -eq $true) { $fEvidence += 'Defender detections mention Liongard.' }
    # Only a finding if the agent is NOT running - a real block stops execution; when the agent is running, these are audit-mode/historical events (reported as context, not a fault).
    if ($fEvidence.Count -and (-not $agentRunning)) {
        Add-Finding -Class 'F' -Confidence 'HIGH' -Title 'Application-control / AV is blocking the agent' -Found $fEvidence -Meaning 'WDAC/AppLocker/AV prevents the agent binary from executing.' -Fix 'Add a publisher/path allow rule for the LiongardAgent binaries in the relevant policy.'
    } elseif ($fEvidence.Count) {
        Write-Report ('  (note: ' + ((Get-FactVal 'Blk.CodeIntegrityHits')) + ' CodeIntegrity/AppLocker events reference Liongard paths, but the agent IS running -> likely audit-mode/historical, not a block)')
    }

    # G - clock skew
    $skew = Get-FactVal 'Time.SkewSeconds'
    if ($skew -ne $null -and (([double]$skew -gt 300) -or ([double]$skew -lt -300))) {
        Add-Finding -Class 'G' -Confidence 'MEDIUM' -Title 'System clock is badly skewed' -Found @('w32tm phase offset = ' + $skew + 's') -Meaning 'Large clock skew breaks certificate/TLS validation; the short-lived signing leaf makes this especially punishing.' -Fix 'Fix time synchronization (w32tm).'
    }

    # H - healthy
    if ($Script:Findings.Count -eq 0) {
        $gatePass = ($exact -eq 0) -or ((Get-FactVal 'Gate.Authenticode') -eq 'Valid')
        if ($gatePass) {
            Add-Finding -Class 'H' -Confidence 'INFO' -Title 'No launch-gate fault found on this machine' -Found @('Signature gate passes; no credential/config/heartbeat errors in the collected window.') -Meaning 'This machine passes every local launch-gate check.' -Fix 'Verify platform-side: the agent record exists and is not deleted, the environment URL is correct, and review the connectivity matrix in network/connectivity.txt.'
        } else {
            Add-Finding -Class 'H' -Confidence 'INFO' -Title 'Inconclusive - review the collected evidence' -Found @('No rule fired but the gate result was not clearly PASS.') -Meaning 'Automated rules did not conclude.' -Fix 'Review certs/gate-replica.txt and eventlog/LiongardAgentLog_last500.txt manually.'
        }
    }

    # --- Write VERDICT block (goes near the top via re-render at Complete) ---
    $order = @{ 'HIGH'=0; 'MEDIUM'=1; 'LOW'=2; 'INFO'=3 }
    $sorted = $Script:Findings | Sort-Object @{ Expression = { $order[$_.Confidence] } }, Class
    Write-Report ''
    Write-Report ('Verdict engine produced ' + $Script:Findings.Count + ' finding(s). See the VERDICT block at the top of report.txt.')
    $Script:SortedFindings = $sorted
}

# --- Bundle assembly ---
function New-DiagZip {
    param([string]$StagingDir, [string]$ZipPath)
    # 1. Compress-Archive - works in FullLanguage (it is a PS script module, so it FAILS under CLM).
    try {
        Compress-Archive -Path (Join-Path $StagingDir '*') -DestinationPath $ZipPath -Force -ErrorAction Stop
        if (Test-Path $ZipPath) { return $true }
    } catch {}
    # 2. .NET ZipFile - FullLanguage only (static method, blocked under CLM).
    if (-not $Script:IsCLM) {
        try {
            Add-Type -AssemblyName System.IO.Compression.FileSystem -ErrorAction Stop
            [System.IO.Compression.ZipFile]::CreateFromDirectory($StagingDir, $ZipPath, [System.IO.Compression.CompressionLevel]::Optimal, $false)
            if (Test-Path $ZipPath) { return $true }
        } catch {}
    }
    # 3. tar.exe (bsdtar, built into Win10+/Server2019+) writes .zip - external binary, CLM-safe; called DIRECTLY (not via Start-Job) because local compression is fast and Start-Job is refused under a manually-downgraded CLM session, making this the reliable CLM zip path.
    try {
        $tar = Join-Path $env:WINDIR 'System32\tar.exe'
        if (Test-Path $tar) {
            & $tar -a -c -f $ZipPath -C $StagingDir "." 2>$null
            if (Test-Path $ZipPath) { return $true }
        }
    } catch {}
    return $false
}

function Complete-Bundle {
    param([string]$OutDir, [string]$BaseName)

    # metadata.json
    $meta = [ordered]@{
        DiagVersion = $Script:DiagVersion
        Computer    = $env:COMPUTERNAME
        StartedLocal= $Script:StartedLoc.ToString('yyyy-MM-dd HH:mm:ss')
        StartedUtc  = $Script:StartedUtc.ToString('yyyy-MM-dd HH:mm:ss')
        DurationSec = [int](Get-ElapsedSec $Script:StartedLoc)
        PSVersion   = $PSVersionTable.PSVersion.ToString()
        PSEdition   = "$($PSVersionTable.PSEdition)"
        LanguageMode= "$Script:LangMode"
        Elevated    = $Script:IsAdmin
        ElevCheck   = $Script:ElevCheckKind
        CanCompile  = $Script:CanCompile
        GateFidelity= (Get-FactVal 'Gate.Fidelity')
        SectionTimes= $Script:SectionTimes
    }
    try { Set-Content -LiteralPath (Join-Path $Script:Staging 'metadata.json') -Value ($meta | ConvertTo-Json -Depth 5) -Encoding ASCII -ErrorAction SilentlyContinue } catch {}

    # errors.txt
    try { Set-Content -LiteralPath (Join-Path $Script:Staging 'errors.txt') -Value $(if ($Script:Errors.Count) { $Script:Errors } else { @('(no section errors)') }) -Encoding ASCII -ErrorAction SilentlyContinue } catch {}

    # Build the final report.txt: VERDICT + QUICK FACTS header, then the buffered detail, then appendices.
    $header = @()
    $header += '================================================================================'
    $header += (' LIONGARD AGENT DIAGNOSTIC v' + $Script:DiagVersion + '    ' + $env:COMPUTERNAME + '   ' + $Script:StartedLoc.ToString('yyyy-MM-dd HH:mm:ss'))
    $header += (' Elevated: ' + $(if ($Script:IsAdmin) { 'YES' } else { 'NO' }) + '   LanguageMode: ' + $Script:LangMode + '   PS ' + $PSVersionTable.PSVersion + '   Runtime: ' + [int](Get-ElapsedSec $Script:StartedLoc) + 's')
    if (-not $Script:IsAdmin) { $header += ' *** RUNNING NON-ELEVATED: admin-only sections were degraded. Re-run elevated for a complete bundle. ***' }
    $header += '================================================================================'
    $header += ''
    $header += '--------------------------------- VERDICT --------------------------------------'
    if ($Script:SortedFindings) {
        $n = 1
        foreach ($fnd in $Script:SortedFindings) {
            $header += (' [' + $n + '] CLASS ' + $fnd.Class + ' (' + $fnd.Confidence + ' confidence) - ' + $fnd.Title)
            $header += '     FOUND:'
            foreach ($e in $fnd.Found) { $header += ('       * ' + $e) }
            $header += ('     MEANING: ' + $fnd.Meaning)
            $header += ('     FIX: ' + $fnd.Fix)
            $header += ''
            $n++
        }
    } else { $header += ' (no findings)'; $header += '' }
    $header += '-------------------------------- QUICK FACTS -----------------------------------'
    $header += ('   Agent version (registry / binary)    : ' + (Get-FactVal 'Reg.ProductVersion') + ' / ' + (Get-FactVal 'Install.GoAgentVersion'))
    $header += ('   Service state / account              : ' + (Get-FactVal 'Svc.State') + ' / ' + (Get-FactVal 'Svc.Account'))
    $header += ('   Go agent process running             : ' + (Get-FactVal 'Proc.GoAgentRunning'))
    $header += ('   Signature gate (Authenticode)        : ' + (Get-FactVal 'Gate.Authenticode') + '   fidelity=' + (Get-FactVal 'Gate.Fidelity'))
    $header += ('   WinVerifyTrust Exact HRESULT         : ' + $(if ($null -ne (Get-FactVal 'Gate.WinTrust.Exact')) { Resolve-HResult ([uint32](Get-FactVal 'Gate.WinTrust.Exact')) } else { 'n/a' }))
    $header += ('   MS root in Root / Disallowed         : ' + (Get-FactVal 'Cert.RootInStore') + ' / ' + (Get-FactVal 'Cert.RootInDisallowed'))
    $header += ('   Last heartbeat success (agent.log)   : ' + (Get-FactVal 'HB.LastSuccess'))
    $header += ('   Restarts in last 24h (crash-loop)    : ' + (Get-FactVal 'Evt.RestartCount24h'))
    $header += ('   DEVELOPMENT_MODE                     : ' + (Get-FactVal 'Config.DevMode'))
    $header += ('   Pre-migration creds still in config  : ' + (Get-FactVal 'Config.PreMigrationSecretsPresent'))
    $header += '--------------------------------------------------------------------------------'

    # Appendix
    $appendix = @()
    $appendix += ''
    $appendix += '================================================================================'
    $appendix += 'APPENDIX A - EVIDENCE MANIFEST'
    $appendix += '================================================================================'
    foreach ($m in $Script:Manifest) {
        try {
            $sha = [string]$m.Sha256
            $shaLen = $(if ($sha.Length -lt 16) { $sha.Length } else { 16 })
            $appendix += ("{0,-55} {1,12} {2}  {3}" -f $m.Path, $m.Bytes, ($sha.Substring(0, $shaLen)), $m.Flags)
        } catch { $appendix += ([string]$m.Path + '  ' + [string]$m.Flags) }
    }
    $appendix += ''
    $appendix += 'APPENDIX B - ERRORS DURING COLLECTION'
    if ($Script:Errors.Count) { foreach ($e in $Script:Errors) { $appendix += ('  ' + $e) } } else { $appendix += '  (none)' }

    $final = $header + $Script:ReportBuffer + $appendix
    try { Set-Content -LiteralPath $Script:ReportPath -Value $final -Encoding ASCII -ErrorAction SilentlyContinue } catch {}

    # Everything for this run goes into ONE folder inside the output location.
    $destFolder = Join-Path $OutDir $BaseName
    try { if (-not (Test-Path -LiteralPath $destFolder)) { New-Item -ItemType Directory -Path $destFolder -Force -ErrorAction Stop | Out-Null } } catch {}
    if (-not (Test-Path -LiteralPath $destFolder)) { $destFolder = $OutDir }   # fall back to flat if folder creation failed

    $zipPath = Join-Path $destFolder ($BaseName + '.zip')
    $ok = New-DiagZip -StagingDir $Script:Staging -ZipPath $zipPath

    Write-Host ''
    if ($ok) {
        # Readable report sits next to the .zip inside the folder.
        try { Copy-Item -LiteralPath $Script:ReportPath -Destination (Join-Path $destFolder ($BaseName + '_report.txt')) -Force -ErrorAction SilentlyContinue } catch {}
        Write-Host ('==> Diagnostic bundle saved to folder:') -ForegroundColor Green
        Write-Host ('      ' + $destFolder) -ForegroundColor Green
        Write-Host ('    Email ' + $BaseName + '.zip (inside that folder) to Liongard support.')
        try { Remove-Item -LiteralPath $Script:Staging -Recurse -Force -ErrorAction SilentlyContinue } catch {}
    } else {
        # No zip (e.g. hardened box without tar): drop the raw collected files into the folder.
        try {
            Set-Content -LiteralPath (Join-Path $Script:Staging 'READ-ME-FIRST.txt') -Value @(
                'Automatic zip creation was not available on this machine.',
                'Please right-click this folder -> Send to -> Compressed (zipped) folder,',
                'then email the resulting .zip to Liongard support.'
            ) -Encoding ASCII -ErrorAction SilentlyContinue
            Get-ChildItem -LiteralPath $Script:Staging -Force -ErrorAction Stop | ForEach-Object {
                Move-Item -LiteralPath $_.FullName -Destination $destFolder -Force -ErrorAction SilentlyContinue
            }
            Remove-Item -LiteralPath $Script:Staging -Recurse -Force -ErrorAction SilentlyContinue
            Write-Host ('==> Could not create a .zip. Collected files are in this folder:') -ForegroundColor Yellow
            Write-Host ('      ' + $destFolder) -ForegroundColor Yellow
            Write-Host '    Please zip that folder and email it to Liongard support.'
        } catch {
            Write-Host ('==> Bundle staging (could not finalize): ' + $Script:Staging) -ForegroundColor Yellow
        }
    }
}

# --- MAIN ---
$ts = Get-Date -Format 'yyyyMMdd-HHmmss'
$baseName = 'LiongardAgent-Diag_' + $env:COMPUTERNAME + '_' + $ts
$outDir = Resolve-OutputDir
$Script:Staging = Join-Path $env:TEMP ('LiongardDiag_' + $ts)

# Create staging tree
$evidenceDirs = @('eventlog','logs','config','registry','certs','install','install\updater-install-logs','install\burn-bundle-logs','tasks','network','security','system')
try {
    New-Item -ItemType Directory -Path $Script:Staging -Force -ErrorAction Stop | Out-Null
    foreach ($d in $evidenceDirs) { New-Item -ItemType Directory -Path (Join-Path $Script:Staging ('evidence\' + $d)) -Force -ErrorAction SilentlyContinue | Out-Null }
} catch {
    Write-Host ('FATAL: could not create staging dir: ' + $_.Exception.Message) -ForegroundColor Red
    exit 1
}
$Script:ReportPath = Join-Path $Script:Staging 'report.txt'

Write-Host ''
Write-Host ('Liongard Agent Diagnostic v' + $Script:DiagVersion + ' - collecting (read-only)...') -ForegroundColor Cyan
Write-Host ('Output will be written to: ' + $outDir)
if (-not $Script:IsAdmin) { Write-Host 'NOTE: not elevated - some sections will be degraded. Re-run elevated for a complete bundle.' -ForegroundColor Yellow }
if ($Script:IsCLM) { Write-Host ('NOTE: Constrained Language Mode active - running degraded (gate fidelity reduced).') -ForegroundColor Yellow }

# Section 00 preflight summary into report
Write-Report ('Preflight: Elevated=' + $Script:IsAdmin + ' (' + $Script:ElevCheckKind + '), LanguageMode=' + $Script:LangMode + ', CanCompile=' + $Script:CanCompile + ', PS=' + $PSVersionTable.PSVersion)
Flush-Report

try {
    Invoke-Section -Id '01' -Index '01/15' -Title 'System snapshot'        -Body { Section-System }
    Invoke-Section -Id '02' -Index '02/15' -Title 'Find agent install'     -Body { Section-FindInstall }
    Invoke-Section -Id '03' -Index '03/15' -Title 'Service state'          -Body { Section-Service }
    Invoke-Section -Id '04' -Index '04/15' -Title 'Agent configuration'    -Body { Section-Config }
    Invoke-Section -Id '05' -Index '05/15' -Title 'Registry forensics'     -Body { Section-Registry }
    Invoke-Section -Id '06' -Index '06/15' -Title 'Signature gate replica' -Body { Section-SignatureGate }
    Invoke-Section -Id '07' -Index '07/15' -Title 'Certificate environment'-Body { Section-CertEnvironment }
    Invoke-Section -Id '08' -Index '08/15' -Title 'Credential path'        -Body { Section-CredentialPath }
    Invoke-Section -Id '09' -Index '09/15' -Title 'Agent event logs'       -Body { Section-EventLogs }
    Invoke-Section -Id '10' -Index '10/15' -Title 'Collect agent logs'     -Body { Section-CollectLogs }
    Invoke-Section -Id '11' -Index '11/15' -Title 'Go agent runtime'       -Body { Section-GoRuntime }
    Invoke-Section -Id '12' -Index '12/15' -Title 'Security controls'      -Body { Section-SecurityControls }
    Invoke-Section -Id '13' -Index '13/15' -Title 'Updater forensics'      -Body { Section-UpdaterForensics }
    Invoke-Section -Id '14' -Index '14/15' -Title 'Connectivity'           -Body { Section-Connectivity }
    Invoke-Section -Id '15' -Index '15/15' -Title 'Verdict engine'         -Body { Invoke-VerdictEngine }
} finally {
    Complete-Bundle -OutDir $outDir -BaseName $baseName
}
